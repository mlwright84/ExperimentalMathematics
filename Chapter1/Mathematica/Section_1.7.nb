Notebook[{

Cell[CellGroupData[{
Cell["Continued Fraction Expressions for \[Pi]", "Title",
 CellChangeTimes->{
  3.840278995204105*^9, {3.840279049317315*^9, 3.84027909469265*^9}, {
   3.840284918776388*^9, 3.840284924028261*^9}, 3.840284956060569*^9, {
   3.845999768058881*^9, 3.845999793366888*^9}, {3.9592106849193573`*^9, 
   3.9592107090296173`*^9}},
 TextAlignment->Center,ExpressionUUID->"3da8eaa4-de85-c449-9dd4-c0d6c989a273"],

Cell[TextData[{
 "Accompanies Section 1.7 of ",
 StyleBox["Experimental Mathematics: A Computational Perspective",
  FontSlant->"Italic"],
 " by Matthew P. Richey and Matthew L. Wright"
}], "Subtitle",
 CellChangeTimes->{{3.846071946694004*^9, 3.846071951019271*^9}, {
   3.8463287390321293`*^9, 3.846328739944585*^9}, {3.959178387747711*^9, 
   3.9591784428734837`*^9}, {3.9591784977036953`*^9, 3.9591785089527645`*^9}, 
   3.959179795914255*^9, 3.9592090383970146`*^9, 3.959210680992031*^9, 
   3.9592107129078693`*^9},
 TextAlignment->Center,
 FontSize->18,ExpressionUUID->"ab8b832f-3811-b240-80a2-72814d858caf"],

Cell[CellGroupData[{

Cell["A Continued Fraction", "Section",
 CellChangeTimes->{{3.963348656601679*^9, 
  3.963348664939575*^9}},ExpressionUUID->"ff1ecec5-83d4-764e-aaef-\
99bc3cec35bb"],

Cell[TextData[{
 "We will compute convergents of the continued fraction ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "+", 
    FractionBox["1", 
     RowBox[{"2", "+", 
      FractionBox["1", 
       RowBox[{"2", "+", 
        FractionBox["1", 
         RowBox[{"2", "+", 
          FractionBox["1", "\[DescendingEllipsis]"]}]]}]]}]]}], 
   TraditionalForm]],ExpressionUUID->"62059d41-fe9f-9a47-b382-58e4e1f177c6"],
 ", which appears in equation (1.15) in the text. "
}], "Text",
 CellChangeTimes->{{3.9623992051182766`*^9, 3.9623992595147133`*^9}, {
  3.9633486762897854`*^9, 
  3.9633487397411575`*^9}},ExpressionUUID->"06e09f99-59fd-e14c-bad3-\
6eab6a8355ee"],

Cell["One way to do this is with the following loop.", "Text",
 CellChangeTimes->{{3.963348741534748*^9, 
  3.9633487581884747`*^9}},ExpressionUUID->"137d00b7-4050-5348-ac2f-\
7bf014b31031"],

Cell[BoxData[
 RowBox[{
  RowBox[{"contFraction", "[", "numLevels_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"initial", " ", "value"}], ";", " ", 
     RowBox[{
     "starts", " ", "at", " ", "the", " ", "\"\<bottom\>\"", " ", "of", " ", 
      "the", " ", "continued", " ", "fraction"}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"val", "=", "2"}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"main", " ", 
      RowBox[{"loop", ":", " ", 
       RowBox[{
       "compute", " ", "another", " ", "level", " ", "of", " ", "the", " ", 
        "fraction", " ", "with", " ", "each", " ", "iteration"}]}]}], " ", 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"val", "=", 
        RowBox[{"2", "+", 
         RowBox[{"1", "/", "val"}]}]}], ",", 
       RowBox[{"numLevels", "-", "1"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "compute", " ", "the", " ", "final", " ", "level", " ", "and", " ", 
       "return", " ", "the", " ", "result"}], " ", "*)"}], " ", 
     "\[IndentingNewLine]", 
     RowBox[{"1", "+", 
      RowBox[{"1", "/", "val"}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.82127951856251*^9, 3.821279651698505*^9}, {
   3.821279693428469*^9, 3.821279699944858*^9}, 3.822066627638648*^9, 
   3.8220667645304346`*^9, 3.9624011400490932`*^9, {3.963348767638962*^9, 
   3.9633489355463047`*^9}},
 CellLabel->
  "In[117]:=",ExpressionUUID->"f0c6f98e-a5c4-9d41-9f06-a86b4597e02a"],

Cell["Now we can compute the first several convergents.", "Text",
 CellChangeTimes->{{3.963348941797777*^9, 
  3.963348951985401*^9}},ExpressionUUID->"c2c58cb0-873c-4748-b48f-\
c6d2d3a3f40a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"contFraction", "/@", 
  RowBox[{"Range", "[", "8", "]"}]}]], "Input",
 CellChangeTimes->{{3.9633488439783764`*^9, 3.9633488508762646`*^9}, 
   3.9633489546102505`*^9},
 CellLabel->
  "In[118]:=",ExpressionUUID->"e0e4f283-8219-1347-af6a-a37882e6f2fc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["3", "2"], ",", 
   FractionBox["7", "5"], ",", 
   FractionBox["17", "12"], ",", 
   FractionBox["41", "29"], ",", 
   FractionBox["99", "70"], ",", 
   FractionBox["239", "169"], ",", 
   FractionBox["577", "408"], ",", 
   FractionBox["1393", "985"]}], "}"}]], "Output",
 CellChangeTimes->{{3.9633488514119644`*^9, 3.9633488592818127`*^9}, 
   3.9633489548582573`*^9},
 CellLabel->
  "Out[118]=",ExpressionUUID->"100639a0-adec-fe4a-8865-5df9a1a7c473"]
}, Open  ]],

Cell["Convert these values to decimal numbers:", "Text",
 CellChangeTimes->{{3.96334900437883*^9, 
  3.9633490112547226`*^9}},ExpressionUUID->"a83c7b66-965d-074d-806f-\
a508c9018a3a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{
   RowBox[{"contFraction", "/@", 
    RowBox[{"Range", "[", "8", "]"}]}], ",", "12"}], "]"}]], "Input",
 CellChangeTimes->{{3.9633488439783764`*^9, 3.9633488508762646`*^9}, {
  3.9633489546102505`*^9, 3.9633489929978905`*^9}},
 CellLabel->
  "In[123]:=",ExpressionUUID->"e004d395-74ee-3d40-88aa-83a709c488ce"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "1.5`12.", ",", "1.4`12.", ",", 
   "1.41666666666666666666666666666666666667`12.", ",", 
   "1.41379310344827586206896551724137931034`12.", ",", 
   "1.41428571428571428571428571428571428571`12.", ",", 
   "1.41420118343195266272189349112426035503`12.", ",", 
   "1.41421568627450980392156862745098039216`12.", ",", 
   "1.41421319796954314720812182741116751269`12."}], "}"}]], "Output",
 CellChangeTimes->{{3.9633489634998837`*^9, 3.96334899326466*^9}},
 CellLabel->
  "Out[123]=",ExpressionUUID->"6e5223c6-e81f-a64d-b77d-ecbb8ab03c44"]
}, Open  ]],

Cell[TextData[{
 "It looks like the values are approaching ",
 Cell[BoxData[
  FormBox[
   SqrtBox["2"], TraditionalForm]],ExpressionUUID->
  "ca67937d-fb0f-384c-8e76-2dddf1088f1f"],
 "."
}], "Text",
 CellChangeTimes->{{3.8220668057513485`*^9, 3.822066839002936*^9}, {
  3.9633490169528236`*^9, 
  3.9633490177050343`*^9}},ExpressionUUID->"e8e2b208-bab9-7f47-bd8a-\
fb5c34eb957a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{
   RowBox[{"Sqrt", "[", "2", "]"}], ",", "12"}], "]"}]], "Input",
 CellChangeTimes->{{3.963348970052351*^9, 3.9633489965672226`*^9}},
 CellLabel->
  "In[124]:=",ExpressionUUID->"0891572b-5dfb-3e41-bae3-71c74d5563ce"],

Cell[BoxData["1.41421356237309504880168872420969807857`12."], "Output",
 CellChangeTimes->{{3.9633489720603237`*^9, 3.963348997108227*^9}},
 CellLabel->
  "Out[124]=",ExpressionUUID->"a907b906-6cad-ff44-8dee-861384c8b9c2"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
