   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Range", "[", "maxTerms", "]"}], ",", 
      RowBox[{"N", "[", 
       RowBox[{"piValues", ",", "10"}], "]"}], ",", "accuracy"}], "}"}], 
    "]"}], ",", 
   RowBox[{"TableHeadings", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"None", ",", 
      RowBox[{"{", 
       RowBox[{"\"\<n\>\"", ",", "\"\<approx\>\"", ",", "\"\<accuracy\>\""}], 
       "}"}]}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8414098877523336`*^9, 3.841409919118642*^9}, 
   3.9633230684986534`*^9},
