Notebook[{

Cell[CellGroupData[{
Cell["Other Inverse Tangent Formulas", "Title",
 CellChangeTimes->{{3.841322393248269*^9, 3.841322396303512*^9}, {
   3.8414091027463083`*^9, 3.8414091128745394`*^9}, {3.959210651844734*^9, 
   3.9592106546297684`*^9}, 3.9633228010197163`*^9},
 TextAlignment->Center,ExpressionUUID->"bdcf15ea-4d5f-4a89-aa5b-42f5e57399ef"],

Cell[TextData[{
 "Accompanies Section 1.4 of ",
 StyleBox["Experimental Mathematics: A Computational Perspective",
  FontSlant->"Italic"],
 " by Matthew P. Richey and Matthew L. Wright"
}], "Subtitle",
 CellChangeTimes->{{3.846071946694004*^9, 3.846071951019271*^9}, {
   3.8463287390321293`*^9, 3.846328739944585*^9}, {3.959178387747711*^9, 
   3.9591784428734837`*^9}, {3.9591784977036953`*^9, 3.9591785089527645`*^9}, 
   3.959179795914255*^9, 3.9592090383970146`*^9, 3.9592106017677746`*^9},
 TextAlignment->Center,
 FontSize->18,ExpressionUUID->"bdbd8bbb-33b1-9a45-b5a9-aeb144a59ed7"],

Cell[CellGroupData[{

Cell["A sum of two arctangent values", "Section",
 CellChangeTimes->{{3.8413232022103777`*^9, 3.841323209755287*^9}, {
  3.8414091563490124`*^9, 
  3.841409162398589*^9}},ExpressionUUID->"26a3a68b-a80e-4b8d-a0cb-\
aa1bc7ff7a4c"],

Cell["\<\
We first consider the formula for \[Pi] from equation (1.7) in the text:\
\>", "Text",
 CellChangeTimes->{{3.841322707308872*^9, 3.8413227580389824`*^9}, {
  3.8413228447573256`*^9, 3.8413228842150264`*^9}, {3.841409195233779*^9, 
  3.8414092066248026`*^9}, {3.963322820348732*^9, 3.963322833220627*^9}, {
  3.9633228648813496`*^9, 
  3.963322865124769*^9}},ExpressionUUID->"63181bad-5229-4251-8711-\
c7b1a3d07633"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox["\[Pi]", "4"], "=", 
   RowBox[{
    RowBox[{"arctan", "(", 
     FractionBox["1", "2"], ")"}], "+", 
    RowBox[{"arctan", "(", 
     FractionBox["1", "3"], ")"}]}]}], 
  TraditionalForm]],ExpressionUUID->"f84e2b0f-853a-424a-bf14-fdbc77b7b5d3"]], \
"Text",
 CellChangeTimes->{{3.841322707308872*^9, 3.8413227580389824`*^9}, {
  3.8413228447573256`*^9, 3.8413228853856163`*^9}, {3.841409216063761*^9, 
  3.8414092354717646`*^9}},
 TextAlignment->Center,ExpressionUUID->"8395180b-2768-4ee3-b36d-0706fd765464"],

Cell["\<\
Converting this formula to a series, we obtain equation (1.8) in the text:\
\>", "Text",
 CellChangeTimes->{{3.8414092419896564`*^9, 3.841409249419443*^9}, {
  3.9633228512876472`*^9, 
  3.963322857013489*^9}},ExpressionUUID->"c9f80633-5833-4a08-a985-\
7765e33601b1"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{"\[Pi]", "\[LongEqual]", "4", 
        UnderoverscriptBox["\[Sum]", 
         RowBox[{
           StyleBox["n", "TI"], "\[LongEqual]", "1"}], "\[Infinity]", 
         LimitsPositioning -> True], 
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", "-1", ")"}], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], 
         RowBox[{"2", 
           StyleBox["n", "TI"], "-", "1"}]], 
        RowBox[{"(", 
          RowBox[{
            FractionBox["1", 
             SuperscriptBox["2", 
              RowBox[{"2", 
                StyleBox["n", "TI"], "-", "1"}]]], "+", 
            FractionBox["1", 
             SuperscriptBox["3", 
              RowBox[{"2", 
                StyleBox["n", "TI"], "-", "1"}]]]}], ")"}]}], 
      TraditionalForm], "errors" -> {}, "input" -> 
    "\\pi=4\\sum_{n=1}^{\\infty} \\frac{(-1)^{n+1}}{2n-1}\\left( \
\\frac{1}{2^{2n-1}}+\\frac{1}{3^{2n-1}}\\right)", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"91bfc82e-5182-48a8-8f3f-bfb5dee796ca"]], \
"Text",
 CellChangeTimes->{3.8462514543025637`*^9},
 TextAlignment->Center,ExpressionUUID->"3b6a017f-d3e5-430a-906b-1523c80a90cc"],

Cell[TextData[{
 "We use a loop with an accumulator to add up partial sums of this series. We \
will put our code for this in a ",
 StyleBox["Module", "Code"],
 " environment for convenient use later. Our module requires one parameter, ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "66621a4d-8c72-4cd1-b76d-6ca81d08ee77"],
 ", the number of terms to add up."
}], "Text",
 CellChangeTimes->{{3.841409382957658*^9, 3.841409469716798*^9}, {
  3.963322880795164*^9, 
  3.963322887350954*^9}},ExpressionUUID->"41d00e0d-a182-41ec-a611-\
e73f2ac532ef"],

Cell[BoxData[
 RowBox[{
  RowBox[{"piSum", "[", "m_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"acc", "=", "0"}], "}"}], ",", " ", 
    RowBox[{"(*", " ", 
     RowBox[{
     "initialize", " ", "the", " ", "accumulator", " ", "as", " ", "a", " ", 
      "local", " ", "variable"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"acc", "+=", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], 
          RowBox[{"n", "+", "1"}]], 
         RowBox[{"(", 
          RowBox[{
           FractionBox["1", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", "n"}], "-", "1"}], ")"}], 
             SuperscriptBox["2", 
              RowBox[{
               RowBox[{"2", "n"}], "-", "1"}]]}]], "+", 
           FractionBox["1", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", "n"}], "-", "1"}], ")"}], 
             SuperscriptBox["3", 
              RowBox[{
               RowBox[{"2", "n"}], "-", "1"}]]}]]}], ")"}]}]}], ",", " ", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "m"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"4", "*", "acc"}]}]}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"return", " ", "value"}], " ", "*)"}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.8395117481274405`*^9, 3.8395117837451024`*^9}, 
   3.8395118951893153`*^9, {3.8409019540956726`*^9, 3.840901959633932*^9}, {
   3.8409020491565027`*^9, 3.8409020739854345`*^9}, {3.8409021879840636`*^9, 
   3.840902201790405*^9}, {3.8409022999235992`*^9, 3.840902302377553*^9}, {
   3.841323290896073*^9, 3.84132333095002*^9}, {3.841324323050247*^9, 
   3.8413243522975655`*^9}, {3.8413248794112835`*^9, 
   3.8413249008985977`*^9}, {3.8414094400436134`*^9, 3.841409440095748*^9}, {
   3.841409491518012*^9, 3.841409536878997*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"ef52aded-223f-49f5-ae2d-7d100baed799"],

Cell[TextData[{
 "Since we wrote our code using whole numbers and fractions, without any \
decimal points or use of the ",
 StyleBox["N",
  FontWeight->"Bold"],
 " function, Mathematica performs the computation using exact arithmetic. \
Thus, the module returns a fraction, which we can convert to a decimal. For \
example, here is the result with ten terms of the sum:"
}], "Text",
 CellChangeTimes->{{3.8414095592773886`*^9, 3.84140967480737*^9}, {
  3.963322908844887*^9, 
  3.9633229343025856`*^9}},ExpressionUUID->"f90c77a8-2a80-4426-ba31-\
eb5e4a67adfe"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"piSum", "[", "10", "]"}], "\[IndentingNewLine]", 
 RowBox[{"N", "[", 
  RowBox[{
   RowBox[{"piSum", "[", "10", "]"}], ",", "20"}], "]"}]}], "Input",
 CellChangeTimes->{{3.841409548946845*^9, 3.8414095729219723`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"ea525bde-f156-47c0-bb10-e6feccd299b7"],

Cell[BoxData[
 FractionBox["154739157603402615025", "49255004804853399552"]], "Output",
 CellChangeTimes->{{3.841409551442398*^9, 3.8414095732499876`*^9}, 
   3.963322918089651*^9},
 CellLabel->"Out[2]=",ExpressionUUID->"1391ff24-8006-d643-90dd-a7b88d19f34a"],

Cell[BoxData["3.1415925796063512109651040110414791129`20."], "Output",
 CellChangeTimes->{{3.841409551442398*^9, 3.8414095732499876`*^9}, 
   3.9633229180946503`*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"e0587747-653b-2349-9791-51505bac3e14"]
}, Open  ]],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s compute many approximations. We\[CloseCurlyQuote]ll \
use the ",
 StyleBox["/@", "Code"],
 " shorthand for the ",
 StyleBox["Map", "Code"],
 " function to compute a list of results."
}], "Text",
 CellChangeTimes->{{3.8414097115647364`*^9, 3.8414097525101585`*^9}, 
   3.846251783966959*^9, {3.963322942396368*^9, 
   3.9633229830296116`*^9}},ExpressionUUID->"a4566833-073c-42e8-b645-\
00474eb4904b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"maxTerms", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"piValues", "=", 
  RowBox[{"piSum", "/@", 
   RowBox[{"Range", "[", "maxTerms", "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.841409723501562*^9, 3.8414097569894457`*^9}, {
  3.841409875771835*^9, 3.8414098838214474`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"ea59e9b2-c1a8-460b-9c37-dcf453e4fdc1"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["10", "3"], ",", 
   FractionBox["505", "162"], ",", 
   FractionBox["6115", "1944"], ",", 
   FractionBox["1538665", "489888"], ",", 
   FractionBox["498668825", "158723712"], ",", 
   FractionBox["21940173935", "6983843328"], ",", 
   FractionBox["10268124795235", "3268438677504"], ",", 
   FractionBox["1108954598674045", "352991377170432"], ",", 
   FractionBox["226226867530011415", "72010240942768128"], ",", 
   FractionBox["154739157603402615025", "49255004804853399552"]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.841409757754885*^9, 3.8414098845778685`*^9, 
  3.963322986593767*^9},
 CellLabel->"Out[5]=",ExpressionUUID->"efc3b021-ff4b-1c47-b114-fbb3b2fca9fb"]
}, Open  ]],

Cell[TextData[{
 "Now we compute the accuracy of each approximation, using the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["log", "10"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "713bf85a-a4a3-f349-a368-a19fd410534c"],
 " method as in the text."
}], "Text",
 CellChangeTimes->{{3.8414097798377805`*^9, 3.841409794370509*^9}, {
  3.9633230041838646`*^9, 
  3.9633230085900764`*^9}},ExpressionUUID->"16141ba1-78f9-49b5-a2fe-\
1a71fc481243"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"accuracy", "=", 
  RowBox[{"N", "[", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"Log", "[", 
      RowBox[{"10", ",", 
       RowBox[{"Abs", "[", 
        RowBox[{"Pi", "-", "piValues"}], "]"}]}], "]"}]}], ",", "5"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.841409798061914*^9, 3.8414098215941615`*^9}, 
   3.9633230731497135`*^9, 3.963323556535614*^9},
 CellLabel->"In[14]:=",ExpressionUUID->"b0fc8fc7-beb3-4906-ae20-d41f6a7eb615"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0.7172857373363549131`5.", ",", "1.6142382129752356145`5.", ",", 
   "2.3997375663942207482`5.", ",", "3.1295423504535087574`5.", ",", 
   "3.8281453419584536712`5.", ",", "4.5077186854459771146`5.", ",", 
   "5.1747442314352639864`5.", ",", "5.8329105415789227048`5.", ",", 
   "6.4844642250334544972`5.", ",", "7.13086546730590862`5."}], 
  "}"}]], "Output",
 CellChangeTimes->{3.8414098224845214`*^9, 3.9633230113989277`*^9, 
  3.963323073753708*^9, 3.9633235569944725`*^9},
 CellLabel->"Out[14]=",ExpressionUUID->"518441aa-307d-9848-909b-987b6e43ba55"]
}, Open  ]],

