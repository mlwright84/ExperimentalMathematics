Cell[TextData[{
 "The plot looks very nearly linear. Without any fancy line-fitting, we could \
simply compute the line through the first and last points of the plot. The \
slope and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "61a6254e-773f-1c49-9359-b0daa2c78f28"],
 "-intercept of that line are as follows:"
}], "Text",
 CellChangeTimes->{{3.963323148290262*^9, 3.9633231589101295`*^9}, {
  3.9633233517029343`*^9, 3.9633234250327053`*^9}, {3.9633235802489357`*^9, 
  3.963323588530939*^9}},ExpressionUUID->"0ad9e228-115f-a749-bab6-\
9229fa8a7163"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"slope", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"accuracy", "[", 
      RowBox[{"[", "maxTerms", "]"}], "]"}], "-", 
     RowBox[{"accuracy", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
   RowBox[{"(", 
    RowBox[{"maxTerms", "-", "1"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.963323210392887*^9, 3.9633232431860104`*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"24da98ef-32f0-fa43-9b9c-55928ec9a63a"],

Cell[BoxData["0.7126199699966170785`4.9123331363201945"], "Output",
 CellChangeTimes->{3.9633232439883747`*^9, 3.9633235638817654`*^9},
 CellLabel->"Out[17]=",ExpressionUUID->"6547ae5e-a0b1-8c4a-910f-076024783b9d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"intercept", "=", 
  RowBox[{
   RowBox[{"accuracy", "[", 
    RowBox[{"[", "1", "]"}], "]"}], "-", "slope"}]}]], "Input",
 CellChangeTimes->{{3.9633234568219433`*^9, 3.9633234583829784`*^9}, {
  3.963323496507328*^9, 3.963323501531542*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"52998f1a-86e7-fd45-9453-4e5e3a777da2"],

Cell[BoxData["0.0046657673397378346`2.4677165018497274"], "Output",
 CellChangeTimes->{3.9633235033336544`*^9, 3.963323564715374*^9},
 CellLabel->"Out[18]=",ExpressionUUID->"dde7c906-c219-fd48-8b9b-419300898d10"]
}, Open  ]],

Cell["\<\
We see that the slope is about 0.7, which means that each additional term of \
the sum increases the accuracy of the approximation of \[Pi] by about 0.7 \
digits. To put it another way, each ten terms of the sum give us about seven \
more digits of \[Pi]. \
\>", "Text",
 CellChangeTimes->{{3.963323711445366*^9, 
  3.963323755096466*^9}},ExpressionUUID->"cda78c0a-bb83-1949-9cbd-\
80f1716bd23a"],

Cell["\<\
Now we will draw the previous plot together with the line through its first \
and last points.\
\>", "Text",
 CellChangeTimes->{{3.9633234270742283`*^9, 3.9633234526789646`*^9}, {
  3.963323598263319*^9, 
  3.9633236100495625`*^9}},ExpressionUUID->"1a83280c-a934-864f-8140-\
48d98ba74e48"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ListPlot", "[", 
    RowBox[{"accuracy", ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<number of terms\>\"", ",", "\"\<accuracy\>\""}], 
       "}"}]}]}], "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"slope", "*", "x"}], "+", "intercept"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "maxTerms"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Orange"}]}], "]"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.9633232805817795`*^9, 3.963323338630615*^9}, {
