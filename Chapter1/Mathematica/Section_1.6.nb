 CellLabel->
  "During evaluation of \
In[97]:=",ExpressionUUID->"b678c5fd-694f-0947-a4c6-52c0cb2dea68"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"approximation of \[Pi]: \"\>", "\[InvisibleSpace]", 
   "3.116`5."}],
  SequenceForm["approximation of \[Pi]: ", 3.116`5.],
  Editable->False]], "Print",
 CellChangeTimes->{{3.9633481271030483`*^9, 3.963348136274893*^9}},
 CellLabel->
  "During evaluation of \
In[97]:=",ExpressionUUID->"2999ffe0-4413-1c4f-9d38-4e19e667e335"]
}, Open  ]]
}, Open  ]],

Cell["\<\
Now we can draw the points (colored according to being a hit or miss) along \
with the circumscribed square and the unit circle.\
\>", "Text",
 CellChangeTimes->{{3.840281095153803*^9, 3.8402811257863894`*^9}, {
  3.840281157170248*^9, 
  3.840281168195331*^9}},ExpressionUUID->"cd67734c-3ac3-fb40-9883-\
9c4ef0e2b497"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Graphics", "[", "\[IndentingNewLine]", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"EdgeForm", "[", "Black", "]"}], ",", 
    RowBox[{"FaceForm", "[", "White", "]"}], ",", 
    RowBox[{"Rectangle", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "1"}], "}"}]}], "]"}], ",", 
    RowBox[{"Circle", "[", "]"}], ",", "\[IndentingNewLine]", "Red", ",", 
    RowBox[{"Point", "[", "hitList", "]"}], ",", "Blue", ",", 
    RowBox[{"Point", "[", "missList", "]"}]}], "}"}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.8402807214905567`*^9, 3.8402808295883493`*^9}, {
   3.840280883466322*^9, 3.840280899929674*^9}, {3.840280971267268*^9, 
