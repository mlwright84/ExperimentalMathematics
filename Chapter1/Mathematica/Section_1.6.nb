   3.9592106858933945`*^9}},
 TextAlignment->Center,ExpressionUUID->"d7cee507-a712-4a6f-bc02-b7a18ab8768f"],

Cell[TextData[{
 "Accompanies Section 1.6 of ",
 StyleBox["Experimental Mathematics: A Computational Perspective",
  FontSlant->"Italic"],
 " by Matthew P. Richey and Matthew L. Wright"
}], "Subtitle",
 CellChangeTimes->{{3.846071946694004*^9, 3.846071951019271*^9}, {
   3.8463287390321293`*^9, 3.846328739944585*^9}, {3.959178387747711*^9, 
   3.9591784428734837`*^9}, {3.9591784977036953`*^9, 3.9591785089527645`*^9}, 
   3.959179795914255*^9, 3.9592090383970146`*^9, 3.959210680992031*^9},
 TextAlignment->Center,
 FontSize->18,ExpressionUUID->"86ea3d2f-0c24-d746-8070-d338ca515a4f"],

Cell[CellGroupData[{

Cell["Dart Board Method", "Section",
 CellChangeTimes->{{3.840279102321122*^9, 3.8402791054725533`*^9}, {
  3.963336587252083*^9, 3.96333658899642*^9}, {3.9633473649105606`*^9, 
  3.9633473664943485`*^9}},ExpressionUUID->"de4a01e3-acaa-4b77-bc94-\
c71dd9d8e4d3"],

Cell[TextData[{
 "We will implement Algorithm 1.28, which computes an approximation of \[Pi] \
using a circular dartboard inscribed in a square sampling region. As \
described in the text, it suffices to randomly select points ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"x", ",", "y"}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "62b921cf-b1f4-294f-871d-c2adfc2f7959"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<=", "x", "<=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4e330df7-b511-c140-8fc2-28a4a5609dd5"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<=", "y", "<=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9fc03b32-94c4-8849-b4ae-baf7c0a9f28e"],
 ". "
}], "Text",
 CellChangeTimes->{{3.84027912076667*^9, 3.8402793109435043`*^9}, {
  3.8402794488002653`*^9, 3.840279492730143*^9}, {3.840292063169168*^9, 
  3.840292065655691*^9}, {3.9633365979966965`*^9, 
  3.9633367324089985`*^9}},ExpressionUUID->"b4110dfb-d9ca-45fc-830b-\
f28d03f2ed43"],

Cell["\<\
Mathematica\[CloseCurlyQuote]s RandomReal function returns random values, \
uniformly selected between 0 and 1.\
\>", "Text",
 CellChangeTimes->{{3.84027912076667*^9, 3.8402793109435043`*^9}, {
  3.8402794488002653`*^9, 3.840279492730143*^9}, {3.840292063169168*^9, 
  3.840292065655691*^9}, {3.9633365979966965`*^9, 
  3.963336745036978*^9}},ExpressionUUID->"9283111d-df8a-4140-b913-\
014f19ce0ce6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RandomReal", "[", "]"}]], "Input",
 CellChangeTimes->{{3.840279651788908*^9, 3.840279689283641*^9}, 
   3.840279753936563*^9, 3.963336754547804*^9},
 CellLabel->"In[46]:=",ExpressionUUID->"28ac2ec6-f172-4a99-be72-f1ed7f5e0750"],

Cell[BoxData["0.6165119095739153`"], "Output",
 CellChangeTimes->{3.9633367552751293`*^9},
 CellLabel->"Out[46]=",ExpressionUUID->"b6d757c0-d4b8-db44-97fe-90668d2dd79e"]
}, Open  ]],

Cell["\<\
Note that you will almost certainly get a new value each time you evaluate \
the code cell above.\
\>", "Text",
 CellChangeTimes->{{3.8402831259417477`*^9, 3.840283146069688*^9}, {
  3.963336762219057*^9, 
  3.963336772170889*^9}},ExpressionUUID->"92ce33a7-f605-4a32-b9fd-\
1637e1b0eebb"],

Cell["Here is an implementation of Algorithm 1.28 in the text:", "Text",
 CellChangeTimes->{{3.846331187556117*^9, 3.846331205415016*^9}, {
  3.9633368017044086`*^9, 
  3.9633368110328045`*^9}},ExpressionUUID->"3f4fa646-f5b7-4ac1-9b11-\
66f14df175e9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dartBoardPi", "[", "m_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "initialize", " ", "an", " ", "accumulator", " ", "and", " ", "other", " ",
      "local", " ", "variables"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"acc", "=", "0"}], ",", " ", "x", ",", " ", "y", ",", " ", 
      "r"}], "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"main", " ", "loop"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "=", 
         RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"y", "=", 
         RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"r", "=", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", 
          RowBox[{"y", "^", "2"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"r", "<", "1"}], ",", 
          RowBox[{"acc", "+=", "1"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", "m", "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"return", " ", "value"}], " ", "*)"}], " ", 
     "\[IndentingNewLine]", 
     RowBox[{"4", "*", 
      RowBox[{"acc", "/", "m"}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.846331208683875*^9, 3.84633126394191*^9}, {
   3.9633368127744102`*^9, 3.9633369007405396`*^9}, 3.963336944284708*^9},
 CellLabel->"In[51]:=",ExpressionUUID->"582c2d7e-9416-4ef9-a736-c0a9c4cc4470"],

Cell["\<\
Run the module and confirm that it produces a value close to \[Pi].\
\>", "Text",
 CellChangeTimes->{{3.8463312892570467`*^9, 3.846331292138538*^9}, {
  3.9633369181381207`*^9, 
  3.963336934030184*^9}},ExpressionUUID->"46cba0f5-c245-4186-8f05-\
e26cf6a81b52"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{"dartBoardPi", "[", "100000", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.846331255903387*^9, 3.8463312844329863`*^9}, {
   3.963336905735317*^9, 3.9633369081647034`*^9}, 3.96333693891234*^9},
 CellLabel->"In[50]:=",ExpressionUUID->"d357d143-e853-49eb-ad73-b22d5e278671"],

Cell[BoxData["3.14324`"], "Output",
 CellChangeTimes->{{3.8463312596305943`*^9, 3.846331284931171*^9}, {
  3.9633369090176544`*^9, 3.963336939650591*^9}},
 CellLabel->"Out[50]=",ExpressionUUID->"66dd7480-5ae9-5e4b-b0a8-9da47b294ce9"]
}, Open  ]],

Cell[TextData[{
 "To get a sense for the randomness in this approximation method, as well as \
how the approximation depends on the number of darts, we will run our \
approximation several times for each number of darts ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Element]", 
    RowBox[{"{", 
     RowBox[{"100", ",", " ", "1000", ",", " ", "10000", ",", " ", "100000"}],
      "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a27ee065-86d7-3647-9484-76d46b197748"],
 "."
}], "Text",
 CellChangeTimes->{{3.840281351130156*^9, 3.840281431584806*^9}, {
  3.8402815413637342`*^9, 3.840281544604871*^9}, {3.9633470542138023`*^9, 
  3.963347130046276*^9}},ExpressionUUID->"d9350193-2836-4bc1-8ceb-\
aadedb6a0623"],

Cell["\<\
Suppose we want to see how variable the resulting approximation as we repeat \
the calculation. Here\[CloseCurlyQuote]s a table of 10 repetitions for M=100, \
1000, 10000, and 100000.\
\>", "Text",
 CellChangeTimes->{{3.840281917550733*^9, 
  3.8402819874642277`*^9}},ExpressionUUID->"ce7458a1-bc29-4d62-977e-\
d666807b92eb"],

