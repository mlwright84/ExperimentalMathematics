  3.9633477641673164`*^9}},ExpressionUUID->"3745fb03-b7a0-8e4e-87c3-\
4ba1861a66fe"],

Cell["\<\
To draw a figure of the dartboard similar to Figure 1.10 in the text, we need \
to keep track of the locations of the darts. The following code does this, \
using two lists to store the locations of darts inside of the circle and \
outside of the circle.\
\>", "Text",
 CellChangeTimes->{{3.8402810258702908`*^9, 3.840281060233049*^9}, {
  3.840281170260871*^9, 3.840281178984413*^9}, {3.9633477861789227`*^9, 
  3.963347856458948*^9}},ExpressionUUID->"550d6121-75cd-3546-85b6-\
c117f53f9416"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"m", "=", "1000"}], ";"}], "    ", 
  RowBox[{"(*", " ", 
   RowBox[{"number", " ", "of", " ", "darts"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"acc", "=", "0"}], ";"}], "       ", 
  RowBox[{"(*", " ", "accumulator", " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"hitList", "=", 
    RowBox[{"{", "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "locations", " ", "of", " ", "darts", " ", "inside", " ", "the", " ", 
    "circle"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"missList", "=", 
    RowBox[{"{", "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "locations", " ", "of", " ", "darts", " ", "outside", " ", "the", " ", 
    "circle"}], " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"main", " ", "loop"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"generate", " ", "random", " ", "values"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"y", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"r", "=", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{"y", "^", "2"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "check", " ", "whether", " ", "the", " ", "dart", " ", "lies", " ", 
       "inside", " ", "the", " ", "circle"}], " ", "*)"}], " ", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"r", "<", "1"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"acc", "+=", "1"}], ";", "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"hitList", ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"missList", ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
      "]"}]}], ",", "\[IndentingNewLine]", "m"}], "]"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"print", " ", "results"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<darts inside circle: \>\"", ",", 
   RowBox[{"Length", "[", "hitList", "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<darts outside circle: \>\"", ",", 
   RowBox[{"Length", "[", "missList", "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<approximation of \[Pi]: \>\"", ",", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"4", "*", 
      RowBox[{"acc", "/", "m"}]}], ",", "5"}], "]"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.840280638579101*^9, 3.840280715779387*^9}, {
  3.840280930198846*^9, 3.840280949001481*^9}, {3.840281062929034*^9, 
  3.840281082718148*^9}, {3.840281141396956*^9, 3.840281146003688*^9}, {
  3.9633478593284264`*^9, 3.9633479450406456`*^9}, {3.963347980868305*^9, 
  3.9633480333171654`*^9}, {3.9633480861012154`*^9, 3.9633481354886417`*^9}},
 CellLabel->"In[97]:=",ExpressionUUID->"efc39920-8e9d-2043-b7ea-77c033654d80"],

