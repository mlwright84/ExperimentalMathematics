Notebook[{

Cell[CellGroupData[{
Cell["Archimedes's Method for Approximating \[Pi]", "Title",
 CellChangeTimes->{{3.839328006657194*^9, 3.839328019850356*^9}, {
   3.84607194218585*^9, 3.846071943166191*^9}, 3.959178547238764*^9},
 TextAlignment->Center,ExpressionUUID->"f0e26973-e2f6-4675-aa52-95c6c69584bd"],

Cell[TextData[{
 "Accompanies Section 1.2 of ",
 StyleBox["Experimental Mathematics: A Computational Perspective",
  FontSlant->"Italic"],
 " by Matthew P. Richey and Matthew L. Wright"
}], "Subtitle",
 CellChangeTimes->{{3.846071946694004*^9, 3.846071951019271*^9}, {
   3.8463287390321293`*^9, 3.846328739944585*^9}, {3.959178387747711*^9, 
   3.9591784428734837`*^9}, {3.9591784977036953`*^9, 3.9591785089527645`*^9}, 
   3.959179795914255*^9},
 TextAlignment->Center,
 FontSize->18,ExpressionUUID->"a5c2892e-c9b5-43aa-b61c-b52f9108e4fd"],

Cell[CellGroupData[{

Cell[TextData[{
 "Approximating \[Pi] with inscribed ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5475aa8d-1c9b-7d4a-917d-7a78c1e4bbf5"],
 "-gons\t"
}], "Section",
 CellChangeTimes->{{3.8394231163384933`*^9, 3.8394231469568634`*^9}, {
  3.846072312634701*^9, 3.8460723133969803`*^9}, {3.84607236920142*^9, 
  3.846072386977242*^9}, {3.959174743402195*^9, 
  3.9591747492176323`*^9}},ExpressionUUID->"debe1426-9c98-4a58-b928-\
3f4d5fb495c4"],

Cell["This is an implementation of Pseudocode 1.4 in Section 1.2.", "Text",
 CellChangeTimes->{{3.8393280333948193`*^9, 3.8393280526268854`*^9}, {
  3.8460724001303387`*^9, 3.846072425609079*^9}, {3.9591747254984837`*^9, 
  3.95917476391457*^9}},ExpressionUUID->"37b9b8c5-7da1-4815-8675-\
dcb73dfa99e9"],

Cell["Set the number of iterations:", "Text",
 CellChangeTimes->{{3.8393280333948193`*^9, 3.8393280526268854`*^9}, {
  3.8460724001303387`*^9, 3.846072430934608*^9}, {3.9591747770899334`*^9, 
  3.9591747791779575`*^9}},ExpressionUUID->"fed78f02-4795-4612-bf58-\
46bfd7d5536d"],

Cell[BoxData[
 RowBox[{"nMax", "=", "10"}]], "Input",
 CellChangeTimes->{{3.839328056612016*^9, 3.8393280614682703`*^9}, 
   3.8393282525967817`*^9, 3.8393395448262253`*^9, 3.839423186840501*^9, 
   3.9591748180699368`*^9},
 CellLabel->"In[3]:=",ExpressionUUID->"df8be85d-221c-41d4-a038-19cdcf456997"],

Cell["Set the initial side length of the inscribed square:", "Text",
 CellChangeTimes->{{3.9591747961234226`*^9, 
  3.9591748062890472`*^9}},ExpressionUUID->"08e52c58-a6c9-e641-aa0a-\
30928f4af5df"],

Cell[BoxData[
 RowBox[{"sideLength", "=", 
  RowBox[{"Sqrt", "[", "2", "]"}]}]], "Input",
 CellChangeTimes->{{3.959174808147812*^9, 3.959174812906063*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"c55bb16d-f45e-534b-8231-69e50229ff4a"],

Cell[TextData[{
 "Initialize a list to store the approximations ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Pi]", "n", "i"], TraditionalForm]],ExpressionUUID->
  "635798bc-ab1d-4178-8224-9d243abf8534"],
 ":"
}], "Text",
 CellChangeTimes->{{3.8393280648688416`*^9, 3.839328162311245*^9}, {
  3.8393282046255116`*^9, 3.8393282178279495`*^9}, {3.8460725428688374`*^9, 
  3.846072545910158*^9}, {3.846086720300478*^9, 3.8460867574789553`*^9}, {
  3.88538089368081*^9, 3.885380900972048*^9}, {3.959174856379244*^9, 
  3.9591748567416973`*^9}},ExpressionUUID->"eb88433d-bd2e-4ac4-ac21-\
0b07c891ce40"],

Cell[BoxData[
 RowBox[{
  RowBox[{"piValues", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", "nMax"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.839328225602556*^9, 3.839328253846575*^9}, {
  3.846086171394503*^9, 3.8460861747620783`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"85299dd2-f913-4513-b215-7d1c0bd95463"],

Cell[TextData[{
 "Include our initial approximation ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Pi]", "2", "i"], TraditionalForm]],ExpressionUUID->
  "c8820b48-9db2-4e15-9c01-f5b2a2794406"],
 " in the list:"
}], "Text",
 CellChangeTimes->{{3.8393282699572706`*^9, 3.839328280586024*^9}, 
   3.8393299658861227`*^9, {3.8853808952609005`*^9, 3.885380922889323*^9}, {
   3.9591748442013206`*^9, 
   3.959174854533766*^9}},ExpressionUUID->"d1cdb1e1-f3d3-4fef-9de1-\
99faec6206fc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"piValues", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}],
    "=", 
   RowBox[{"2", "*", "sideLength"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.8393282857504735`*^9, 3.8393283350243487`*^9}, {
  3.846086179386441*^9, 3.846086194079454*^9}, {3.9591748363308487`*^9, 
  3.9591748369572773`*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"637cccc8-2549-4db4-bd6e-50c9714635f1"],

Cell[TextData[{
 "Use a loop to compute  ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Pi]", "n", "i"], TraditionalForm]],ExpressionUUID->
  "6b9a44fa-beba-44f2-94af-8a723f0fbea0"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "=", "3"}], ",", "4", ",", "...", ",", "nMax"}], 
   TraditionalForm]],ExpressionUUID->"f3e37335-c8ec-439f-ba9b-ab983c09ade1"],
 ". The following code uses a ",
 StyleBox["For", "Code"],
 " loop, the syntax of which is very similar to the pseudocode in the text. \
Note that Mathematica requires that multiple expressions in the body of the \
loop to be separated by semicolons. Note the recurring use of the variable ",
 StyleBox["sideLength", "Code"],
 StyleBox[".",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.8393283435006123`*^9, 3.83932838092912*^9}, {
  3.8393287387096276`*^9, 3.839328789984234*^9}, {3.839328943305991*^9, 
  3.8393290358142023`*^9}, {3.846086776722762*^9, 3.8460867789773417`*^9}, {
  3.846087429158399*^9, 3.846087441885612*^9}, {3.9591749147433033`*^9, 
  3.9591749341564903`*^9}},ExpressionUUID->"7314518d-05a9-483f-9f56-\
3224132238a6"],

Cell[BoxData[
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"n", "=", "3"}], ",", 
   RowBox[{"n", "<=", "nMax"}], ",", 
   RowBox[{"n", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Compute", " ", "a", " ", "and", " ", "b", "  ", "values"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"a", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"b", "=", 
     RowBox[{"1", "-", "a"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "Compute", " ", "the", " ", "new", " ", "side", " ", "length", " ", 
      "and", " ", "perimeter"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{"sideLength", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       SuperscriptBox["b", "2"], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"perimeter", " ", "=", " ", 
     RowBox[{
      SuperscriptBox["2", "n"], "*", " ", "sideLength"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "Compute", " ", "the", " ", "approximation", " ", "to", " ", "pi"}], " ",
      "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
     "piValues", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}], "=", 
     RowBox[{"perimeter", "/", "2"}]}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.839328565974078*^9, 3.8393285784977713`*^9}, {
  3.8393287208111315`*^9, 3.839328722649518*^9}, {3.8393397838422685`*^9, 
  3.8393397886873617`*^9}, {3.839339892267519*^9, 3.8393398946428194`*^9}, {
  3.8460861998237267`*^9, 3.846086216688661*^9}, {3.846086764222733*^9, 
  3.846086823213705*^9}, {3.8853809316517467`*^9, 3.885380951624426*^9}, {
  3.959174950096924*^9, 3.959174996911272*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"2b96a197-3175-4b98-b4f2-7834af23d515"],

Cell[TextData[{
 "Now we can print the results. The results are stored internally as \
algebraic expressions involving lots of square roots, so we use the ",
 StyleBox[ButtonBox["N",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/N.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/N.html"], "Code",
  FontVariations->{"Underline"->True}],
 " function to print them as decimal numbers. (To understand this, run the \
following code with and without the ",
 StyleBox["N", "Code"],
 ".)"
}], "Text",
 CellChangeTimes->{{3.8393287920843983`*^9, 3.839328796209746*^9}, {
  3.83932883103655*^9, 3.8393289218239374`*^9}, {3.9591750155085983`*^9, 
  3.9591750228345966`*^9}, {3.9591750776453*^9, 
  3.959175083476492*^9}},ExpressionUUID->"0dc8cacd-3370-4838-a91a-\
8167f0af712c"],

Cell[BoxData[
 RowBox[{"N", "[", "piValues", "]"}]], "Input",
 CellChangeTimes->{{3.8393288064262066`*^9, 3.8393288251492763`*^9}, {
  3.839339793094615*^9, 3.8393397945977683`*^9}, {3.846086222090783*^9, 
  3.8460862541355753`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"69111684-abeb-4b03-9dd5-e042b096e894"],

Cell[TextData[{
 "Mathematica also provides a ",
 StyleBox["Do", "Code"],
 " loop, which is functionally equivalent to the ",
 StyleBox["For", "Code"],
 " loop but has a slightly simpler syntax that specifies the counter variable \
after the body of the loop . "
}], "Text",
 CellChangeTimes->{{3.839329027208593*^9, 3.839329031730159*^9}, {
  3.8393290784683914`*^9, 3.8393291003645744`*^9}, {3.9591751216600304`*^9, 
  3.959175147997404*^9}},ExpressionUUID->"722abd48-5e12-493b-b453-\
e176e992a8e7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"sideLength", "=", 
   RowBox[{"Sqrt", "[", "2", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Compute", " ", "a", " ", "and", " ", "b", "  ", "values"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"a", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"b", "=", 
     RowBox[{"1", "-", "a"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "Compute", " ", "the", " ", "new", " ", "side", " ", "length", " ", 
      "and", " ", "perimeter"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{"sideLength", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       SuperscriptBox["b", "2"], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"perimeter", " ", "=", " ", 
     RowBox[{
      SuperscriptBox["2", "n"], "*", " ", "sideLength"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "Compute", " ", "the", " ", "approximation", " ", "to", " ", "pi"}], " ",
      "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
     "piValues", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}], "=", 
     RowBox[{"perimeter", "/", "2"}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"n", ",", "3", ",", "nMax"}], "}"}]}], "\[IndentingNewLine]", 
  "]"}]}], "Input",
 CellChangeTimes->{{3.8393283860450554`*^9, 3.8393285393277693`*^9}, {
   3.839424246296171*^9, 3.839424248042228*^9}, {3.846086263613233*^9, 
   3.846086273346222*^9}, {3.846086321946949*^9, 3.8460863258062363`*^9}, {
   3.846086791857275*^9, 3.846086792305869*^9}, {3.8460868301690607`*^9, 
   3.8460868346091547`*^9}, {3.8853809896509733`*^9, 3.885380998490092*^9}, 
   3.959175165554718*^9},
 CellLabel->"In[10]:=",ExpressionUUID->"e8bcb078-74c4-4988-8d9d-eed89c00a3ad"],

Cell[TextData[{
 "The ",
 StyleBox["N", "Code"],
 " function can convert an exact value to any specified number of decimal \
digits, as shown below with ten digits."
}], "Text",
 CellChangeTimes->{{3.9591751905821896`*^9, 
  3.9591752164243507`*^9}},ExpressionUUID->"bcbe722a-1c90-8f44-9844-\
d11227302d49"],

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{"piValues", ",", "10"}], "]"}]], "Input",
 CellChangeTimes->{{3.841144007803937*^9, 3.841144017267536*^9}, {
   3.841145424350175*^9, 3.8411454320412807`*^9}, 3.846086289563821*^9, 
   3.885381005332427*^9},
 CellLabel->"In[12]:=",ExpressionUUID->"6bae32d7-5ed1-4696-9581-27075cb05190"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Accuracy", "Section",
 CellChangeTimes->{{3.8393390443417015`*^9, 
  3.8393390497138786`*^9}},ExpressionUUID->"b74a5dfa-7d39-4e76-a5c4-\
d90454f4fb5a"],

Cell[TextData[{
 "How accurate are our approximations? First, we will find the difference \
between our approximations and Mathematica\[CloseCurlyQuote]s value of \[Pi], \
which can be accessed via the keyword ",
 StyleBox["Pi", "Code"],
 "."
}], "Text",
 CellChangeTimes->{{3.8394243806320333`*^9, 3.8394244169517813`*^9}, {
  3.83950366841276*^9, 3.839503670114395*^9}, {3.9591752826548977`*^9, 
  3.959175290153101*^9}, {3.9591753318277016`*^9, 
  3.959175335627619*^9}},ExpressionUUID->"e7a659d3-a6e7-473d-a8e6-\
f90846f8ef4d"],

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{"Pi", "-", "piValues"}], "]"}]], "Input",
 CellChangeTimes->{{3.839337956609527*^9, 3.8393379606023445`*^9}, {
  3.839338012376995*^9, 3.8393380155945697`*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"b5288b72-2929-486c-9c3a-711bf15f1b95"],

Cell["\<\
The negative log of the difference is approximately the number of correct \
digits in our approximation. (See Pseudocode 1.9 and adjacent discussion in \
the text.)\
\>", "Text",
 CellChangeTimes->{{3.8394244336968927`*^9, 3.8394244552326765`*^9}, {
  3.9591753706300583`*^9, 
  3.959175382094721*^9}},ExpressionUUID->"199a206e-7794-44f2-9ee5-\
b05bc2131408"],

Cell[BoxData[
 RowBox[{"accuracy", "=", 
  RowBox[{"N", "[", 
   RowBox[{"-", 
    RowBox[{"Log", "[", 
     RowBox[{"10", ",", 
      RowBox[{"Pi", "-", "piValues"}]}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8393379941847734`*^9, 3.8393380324802876`*^9}, {
  3.839338089639231*^9, 3.8393380934666557`*^9}, {3.8393382298928185`*^9, 
  3.839338233206504*^9}, {3.839424422455903*^9, 3.839424423800742*^9}, {
  3.8394246088231144`*^9, 3.8394246099822054`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"d6bd7c16-36d9-4b60-abb9-3eff92de0e47"],

Cell[TextData[{
 "We can display our approximations and the numbers of correct digits for \
each ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "745e2d6f-4ec8-4c71-a424-dca64d5f3e26"],
 " in table form:"
}], "Text",
 CellChangeTimes->{{3.8394245131265297`*^9, 
  3.8394245415972853`*^9}},ExpressionUUID->"7c2e4f9a-b4b3-4f89-b14c-\
e7412dd62ed2"],

Cell[BoxData[
 RowBox[{"TableForm", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Range", "[", "nMax", "]"}], ",", 
     RowBox[{"N", "[", "piValues", "]"}], ",", "accuracy"}], "}"}], ",", 
   RowBox[{"TableHeadings", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<n\>\"", ",", "\"\<approx\>\"", ",", "\"\<accuracy\>\""}], 
       "}"}], ",", "None"}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.839338070470482*^9, 3.839338108153427*^9}, {
  3.839338251831539*^9, 3.8393382553758583`*^9}, {3.83933838657477*^9, 
  3.839338414559239*^9}, {3.8394244647954865`*^9, 3.839424509949297*^9}, {
  3.8394246175169797`*^9, 3.839424622710176*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"4a65f344-7de1-49c5-8b9c-fa320def5c73"],

Cell[TextData[{
 "A plot shows that our accuracy increases linearly with ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "cefd9d07-2fae-4a3d-bcc9-8c22b30af95a"],
 ":"
}], "Text",
 CellChangeTimes->{{3.8394250858572536`*^9, 
  3.839425113236532*^9}},ExpressionUUID->"615a61ac-d2d5-4e5c-9f64-\
41a53b7aa5ca"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"accuracy", "\[LeftDoubleBracket]", 
    RowBox[{"2", ";;"}], "\[RightDoubleBracket]"}], ",", 
   RowBox[{"DataRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"2", ",", "nMax"}], "}"}]}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<n\>\"", ",", "\"\<accuracy\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.8394246005918264`*^9, 3.839424628194461*^9}, {
  3.839424801903924*^9, 3.8394248286307087`*^9}, {3.8394250420361967`*^9, 
  3.839425055641504*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"f1ccac33-e63a-4df1-84b2-d10ede94d185"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Efficiency", "Section",
 CellChangeTimes->{{3.839425127733127*^9, 
  3.8394251319515824`*^9}},ExpressionUUID->"6f86353f-f7ad-4e59-aa42-\
3a9935745753"],

Cell[TextData[{
 "Mathematica has a a built-in function called ",
 StyleBox[ButtonBox["Timing",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Timing.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Timing.html"], 
  "Code"],
 StyleBox[" ",
  FontWeight->"Bold"],
 "which will help us analyze the efficiency of our algorithm for \
approximating \[Pi]."
}], "Text",
 CellChangeTimes->{{3.839426711863352*^9, 3.8394267310727034`*^9}, {
   3.8460757580031023`*^9, 3.84607581310823*^9}, {3.84607587778605*^9, 
   3.846075970078437*^9}, 3.84616096233202*^9, {3.959175424696518*^9, 
   3.9591754899291515`*^9}},ExpressionUUID->"488d9fc7-7b84-4da7-b2c3-\
f74cd8b71dee"],

Cell[TextData[{
 "Here is a simple example of how ",
 StyleBox["Timing", "Code"],
 " works. Suppose we wanted to determine the time required to add up ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         UnderoverscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["n", "TI"], "\[LongEqual]", "1"}], 
          StyleBox["N", "TI"], LimitsPositioning -> True], 
         FractionBox["1", 
          SuperscriptBox[
           StyleBox["n", "TI"], "2"]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\sum_{n=1}^{N}\\frac{1}{n^2}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1655103e-e479-6248-a6e4-6ca9055e3ffe"],
 " for some large value of ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "0b02714b-7777-fe49-a744-e519821449a1"],
 ". We could do this as follows:"
}], "Text",
 CellChangeTimes->{{3.839426711863352*^9, 3.8394267310727034`*^9}, {
   3.8460757580031023`*^9, 3.84607581310823*^9}, {3.84607587778605*^9, 
   3.846075970078437*^9}, 3.84616096233202*^9, {3.959175424696518*^9, 
   3.9591755203949337`*^9}},ExpressionUUID->"ae9d918c-0ef5-fd43-89df-\
c6af133a36ba"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"nMax", "=", "10000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Timing", "[", 
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{"N", "[", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["n", "2"]], ",", "20"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", "nMax"}], "}"}]}], "]"}], "]"}]}], "Input",
 CellChangeTimes->{{3.846075817312809*^9, 3.846075872888708*^9}, {
  3.9591755248881645`*^9, 3.959175527249363*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"1136c971-c993-4ded-b275-fedf248a7cb7"],

Cell[TextData[{
 "The return value of ",
 StyleBox["Timing", "Code"],
 " is a list of two values. The first element is the time required (what we \
want) and the second element is the value computed. So if we just wanted the \
time required for this computation, we could extract it."
}], "Text",
 CellChangeTimes->{{3.8460759741558723`*^9, 
  3.846076041486788*^9}},ExpressionUUID->"bf037cee-8f10-4943-b4f1-\
12e2114ac7ff"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"nMax", "=", "10000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"theTime", "=", 
  RowBox[{
   RowBox[{"Timing", "[", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"N", "[", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox["n", "2"]], ",", "20"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", "nMax"}], "}"}]}], "]"}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.846076050414403*^9, 3.846076055693707*^9}, 
   3.9591755480616837`*^9},
 CellLabel->"In[19]:=",ExpressionUUID->"e2aba1bf-6f4d-412d-9190-e7b18ad0966b"],

Cell[TextData[{
 "Here is one way to measure the runtime of our approximation code for ",
 StyleBox["nMax", "Code",
  FontWeight->"Bold"],
 " iterations."
}], "Text",
 CellChangeTimes->{{3.839426711863352*^9, 3.8394267310727034`*^9}, {
  3.8460757580031023`*^9, 3.846075810407778*^9}, {3.959175551858595*^9, 
  3.9591755636713543`*^9}},ExpressionUUID->"3f4db183-23cd-4404-af5e-\
a1afbf47837f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"initialize", " ", "values"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"nMax", "=", "10"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sideLength", "=", 
     RowBox[{"Sqrt", "[", "2", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"piValues", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", "nMax"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
     "piValues", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "=", 
     RowBox[{"2", "*", "sideLength"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "run", " ", "the", " ", "loop", " ", "and", " ", "store", " ", "the", " ",
      "runtime"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"runtime1", "=", 
     RowBox[{
      RowBox[{"Timing", "[", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"Compute", " ", "a", " ", "and", " ", "b", "  ", "values"}], 
         " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"a", "=", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"1", "-", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"b", "=", 
           RowBox[{"1", "-", "a"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Compute", " ", "the", " ", "new", " ", "side", " ", "length", " ",
             "and", " ", "perimeter"}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"sideLength", "=", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             SuperscriptBox["b", "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"perimeter", " ", "=", " ", 
           RowBox[{
            SuperscriptBox["2", "n"], "*", " ", "sideLength"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Compute", " ", "the", " ", "approximation", " ", "to", " ", 
            "pi"}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
           "piValues", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}],
            "=", 
           RowBox[{"perimeter", "/", "2"}]}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"n", ",", "3", ",", "nMax"}], "}"}]}], 
        "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}], "\[LeftDoubleBracket]",
       "1", "\[RightDoubleBracket]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "the", " ", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], " ", 
     "stores", " ", "only", " ", "the", " ", "first", " ", "value", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"i", ".", "e", "."}], ",", " ", 
       RowBox[{"the", " ", "runtime"}]}], ")"}], " ", "returned", " ", "by", " ",
      "Timing"}], " ", "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.8393390371544123`*^9, 3.8393390405259542`*^9}, {
   3.839425785655071*^9, 3.839425855258587*^9}, {3.8394259054666877`*^9, 
   3.8394259130318723`*^9}, {3.8394259487287617`*^9, 3.839425949353894*^9}, 
   3.839426095326118*^9, {3.839426126460825*^9, 3.8394262044982567`*^9}, {
   3.839426546242377*^9, 3.8394265615365915`*^9}, 3.8394267007557945`*^9, {
   3.841144146731913*^9, 3.8411441619544287`*^9}, {3.84114419397616*^9, 
   3.841144195040254*^9}, {3.841144353640024*^9, 3.8411443550133057`*^9}, {
   3.8460863576038513`*^9, 3.846086384718998*^9}, {3.846086422464027*^9, 
   3.846086437799981*^9}, {3.846086473322238*^9, 3.8460864950968943`*^9}, {
   3.846086847511139*^9, 3.846086850784565*^9}, {3.846087079925948*^9, 
   3.8460870809389343`*^9}, {3.846087145337583*^9, 3.84608714621986*^9}, {
   3.9591755767351284`*^9, 3.959175579476103*^9}, {3.9591757549304276`*^9, 
   3.9591757880822926`*^9}, 3.959175859260887*^9, {3.9591762419619637`*^9, 
   3.9591762543827057`*^9}, 3.9591763660273495`*^9},
 CellLabel->"In[71]:=",ExpressionUUID->"c7109900-cb40-4f0a-a599-f1006591312c"],

Cell[TextData[{
 "Show the runtime and the decimal approximations of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Pi]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\pi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "857a560d-752e-495d-8a46-a6b636cfdf37"],
 ":"
}], "Text",
 CellChangeTimes->{{3.846086876573208*^9, 3.8460869223056583`*^9}, {
  3.959175719164852*^9, 
  3.95917573161495*^9}},ExpressionUUID->"789c4d75-1b4a-470c-8b98-\
4c0872ac00d6"],

Cell[BoxData[{"runtime1", "\[IndentingNewLine]", 
 RowBox[{"N", "[", 
  RowBox[{"piValues", ",", "15"}], "]"}]}], "Input",
 CellChangeTimes->{{3.8393390371544123`*^9, 3.8393390405259542`*^9}, {
   3.839425785655071*^9, 3.839425855258587*^9}, {3.8394259054666877`*^9, 
   3.8394259130318723`*^9}, {3.8394259487287617`*^9, 3.839425949353894*^9}, 
   3.839426095326118*^9, {3.839426126460825*^9, 3.8394262044982567`*^9}, {
   3.839426546242377*^9, 3.8394265615365915`*^9}, 3.8394267007557945`*^9, {
   3.841144146731913*^9, 3.8411441619544287`*^9}, {3.84114419397616*^9, 
   3.841144195040254*^9}, {3.841144353640024*^9, 3.8411443550133057`*^9}, {
   3.8460863576038513`*^9, 3.846086384718998*^9}, 3.846086422464027*^9, {
   3.846086485031732*^9, 3.846086488395246*^9}, {3.846086520864025*^9, 
   3.8460865210031223`*^9}, {3.846086925338581*^9, 3.8460869285946903`*^9}},
 CellLabel->"In[76]:=",ExpressionUUID->"481a1ff1-910a-4450-b484-0e8708b1c517"],

Cell[TextData[{
 "This code may seem to run quite fast. However, try increasing the value of ",
 StyleBox["nMax", "Code"],
 " and running it again! You will probably find that the code takes a very \
long time to run when ",
 StyleBox["nMax", "Code"],
 " is as large as 15 or 18."
}], "Text",
 CellChangeTimes->{{3.8394267456589684`*^9, 3.8394268643502254`*^9}, {
  3.959176374287163*^9, 
  3.959176374588043*^9}},ExpressionUUID->"e0030768-8c17-435b-9601-\
b21a93a79f95"],

Cell[TextData[{
 "The reason for this long runtime is that Mathematica is computing very \
large algebraic expressions involving nested square roots. Print the first \
four elements in ",
 StyleBox["piValues", "Code"],
 " to see some:"
}], "Text",
 CellChangeTimes->{{3.839426865896416*^9, 3.83942691745382*^9}, {
  3.840898827303377*^9, 
  3.840898832187545*^9}},ExpressionUUID->"e803e384-ca49-423b-a545-\
4fa1140eb517"],

Cell[BoxData[
 RowBox[{"piValues", "\[LeftDoubleBracket]", 
  RowBox[{";;", "4"}], "\[RightDoubleBracket]"}]], "Input",
 CellChangeTimes->{{3.839426902590954*^9, 3.8394269037904367`*^9}, {
  3.8408988197231336`*^9, 3.840898822530035*^9}},
 CellLabel->
  "In[168]:=",ExpressionUUID->"307e6422-4c43-41b0-a250-cf6307496e09"],

Cell[TextData[{
 "We can improve the efficiency of our code by asking Mathematica to simplify \
each side length as it computes them. Mathematica provides a ",
 StyleBox["Simplify", "Code"],
 " function that does exactly this. Here is another copy of the code with ",
 StyleBox["Simplify", "Code"],
 " inserted into the loop:"
}], "Text",
 CellChangeTimes->{{3.8394269774951506`*^9, 3.83942703707423*^9}, {
  3.839427077014367*^9, 3.839427090510086*^9}, {3.8394272296802607`*^9, 
  3.839427231553906*^9}},ExpressionUUID->"7551ef9d-597d-4adb-b9c8-\
91efd922fe52"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"initialize", " ", "values"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"nMax", "=", "10"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sideLength", "=", 
     RowBox[{"Sqrt", "[", "2", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"piValues", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", "nMax"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
     "piValues", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "=", 
     RowBox[{"2", "*", "sideLength"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "run", " ", "the", " ", "loop", " ", "and", " ", "store", " ", "the", " ",
      "runtime"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"runtime2", "=", 
     RowBox[{
      RowBox[{"Timing", "[", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"Compute", " ", "a", " ", "and", " ", "b", "  ", "values"}], 
         " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"a", "=", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"1", "-", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"b", "=", 
           RowBox[{"1", "-", "a"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Compute", " ", "the", " ", "new", " ", "side", " ", "length", " ",
             "and", " ", "perimeter"}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"sideLength", "=", 
           RowBox[{"Simplify", "[", 
            RowBox[{"Sqrt", "[", 
             RowBox[{
              SuperscriptBox["b", "2"], "+", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}], 
            "]"}]}], ";", " ", 
          RowBox[{"(*", " ", 
           RowBox[{
           "note", " ", "the", " ", "use", " ", "of", " ", "Simplify", " ", 
            "here"}], " ", "*)"}], " ", "\[IndentingNewLine]", 
          RowBox[{"perimeter", " ", "=", " ", 
           RowBox[{
            SuperscriptBox["2", "n"], "*", " ", "sideLength"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Compute", " ", "the", " ", "approximation", " ", "to", " ", 
            "pi"}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
           "piValues", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}],
            "=", 
           RowBox[{"perimeter", "/", "2"}]}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"n", ",", "3", ",", "nMax"}], "}"}]}], 
        "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}], "\[LeftDoubleBracket]",
       "1", "\[RightDoubleBracket]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "the", " ", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], " ", 
     "stores", " ", "only", " ", "the", " ", "first", " ", "value", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"i", ".", "e", "."}], ",", " ", 
       RowBox[{"the", " ", "runtime"}]}], ")"}], " ", "returned", " ", "by", " ",
      "Timing"}], " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "output", " ", "*)"}], "\[IndentingNewLine]", 
   "runtime2", "\[IndentingNewLine]", 
   RowBox[{"N", "[", 
    RowBox[{"piValues", ",", "15"}], "]"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"note", ":", " ", 
     RowBox[{
     "number", " ", "of", " ", "output", " ", "digits", " ", "here"}]}], " ", 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.8393390371544123`*^9, 3.8393390405259542`*^9}, {
   3.839425785655071*^9, 3.839425855258587*^9}, {3.8394259054666877`*^9, 
   3.8394259130318723`*^9}, {3.8394259487287617`*^9, 3.839425949353894*^9}, 
   3.839426095326118*^9, {3.839426126460825*^9, 3.8394262044982567`*^9}, {
   3.839426546242377*^9, 3.8394265615365915`*^9}, 3.8394267007557945`*^9, {
   3.839427050879068*^9, 3.839427101417864*^9}, {3.8394271482935095`*^9, 
   3.83942714837164*^9}, {3.8394271826966076`*^9, 3.839427267156108*^9}, {
   3.839427773555684*^9, 3.839427834268521*^9}, {3.839427948135581*^9, 
   3.839427965300494*^9}, {3.83942801228706*^9, 3.8394280257606397`*^9}, 
   3.8394280679777164`*^9, {3.8394281715375166`*^9, 3.8394281780216265`*^9}, {
   3.841144125401819*^9, 3.841144125688978*^9}, {3.841144175869357*^9, 
   3.841144176620921*^9}, {3.841144279148656*^9, 3.841144280108746*^9}, {
   3.841144357833435*^9, 3.841144360093772*^9}, {3.846086956053409*^9, 
   3.846087006642743*^9}, {3.959176398353903*^9, 3.9591764337163086`*^9}, {
   3.9591764812266464`*^9, 3.9591765224306374`*^9}, 3.9591765723543053`*^9},
 CellLabel->
