Cell[TextData[{
 "The code above should run reasonably for ",
 StyleBox["nMax", "Code"],
 " values such as 40 or 50. However, larger values such as 200 will still \
require long runtimes."
}], "Text",
 CellChangeTimes->{{3.8394278696578517`*^9, 3.8394279313029556`*^9}, {
  3.839428071806965*^9, 3.8394281369261503`*^9}, {3.9591764547260246`*^9, 
  3.9591764747890377`*^9}, {3.959176513713455*^9, 
  3.959176517215893*^9}},ExpressionUUID->"961c8a70-8845-4d06-be12-\
6c8447f9ea96"],

Cell[TextData[{
 "Another option is that we could use decimal values throughout the \
computation. The following code cell defines the ",
 StyleBox["sideLength", "Code"],
 " variable using 30 digits of precision. Mathematica then carries this level \
of precision throughout the computation. Note that we do not need to use the ",
 StyleBox["Simplify", "Code"],
 " function in this case."
}], "Text",
 CellChangeTimes->{{3.839428180521434*^9, 3.839428299035388*^9}, {
  3.9591766613930264`*^9, 3.9591766940705967`*^9}, {3.959176750282177*^9, 
  3.959176830997341*^9}},ExpressionUUID->"b44c8a91-230d-43ab-87da-\
d68a9158cda1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"initialize", " ", "values"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"nMax", "=", "15"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"precision", "=", "30"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sideLength", "=", 
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{"Sqrt", "[", "2", "]"}], ",", "precision"}], "]"}]}], ";"}], 
   "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"note", " ", "precision", " ", "specificiation", " ", "here"}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"piValues", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", "nMax"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
     "piValues", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "=", 
     RowBox[{"2", "*", "sideLength"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "run", " ", "the", " ", "loop", " ", "and", " ", "store", " ", "the", " ",
      "runtime"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"runtime3", "=", 
     RowBox[{
      RowBox[{"Timing", "[", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"Compute", " ", "a", " ", "and", " ", "b", "  ", "values"}], 
         " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"a", "=", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"1", "-", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"b", "=", 
           RowBox[{"1", "-", "a"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Compute", " ", "the", " ", "new", " ", "side", " ", "length", " ",
             "and", " ", "perimeter"}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"sideLength", "=", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             SuperscriptBox["b", "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}]}], ";", 
          "  ", "\[IndentingNewLine]", 
          RowBox[{"perimeter", " ", "=", " ", 
           RowBox[{
            SuperscriptBox["2", "n"], "*", " ", "sideLength"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Compute", " ", "the", " ", "approximation", " ", "to", " ", 
            "pi"}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
           "piValues", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}],
            "=", 
           RowBox[{"perimeter", "/", "2"}]}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"n", ",", "3", ",", "nMax"}], "}"}]}], 
        "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}], "\[LeftDoubleBracket]",
       "1", "\[RightDoubleBracket]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "the", " ", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], " ", 
     "stores", " ", "only", " ", "the", " ", "first", " ", "value", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"i", ".", "e", "."}], ",", " ", 
       RowBox[{"the", " ", "runtime"}]}], ")"}], " ", "returned", " ", "by", " ",
      "Timing"}], " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "output", " ", "*)"}], "\[IndentingNewLine]", 
   "runtime3", "\[IndentingNewLine]", "piValues"}]}]], "Input",
 CellChangeTimes->{{3.9591765921035576`*^9, 3.959176613507353*^9}, {
  3.9591766999446697`*^9, 3.95917674450008*^9}, {3.959176836612568*^9, 
  3.9591768478836517`*^9}},
 CellLabel->
  "In[151]:=",ExpressionUUID->"938c9607-7f4d-7941-8fb1-649da8873ff3"],

Cell[TextData[{
 "Comparing all three  versions, we see that there is a significant \
difference in runtimes.  In particular, the first version is markedly less \
efficient due to the unsimplified algebraic expressions. Simplifying the key \
expressions greatly improves the efficiency while still preserving the exact \
form of all the expressions. If the goal is simply numerical precision, the \
last form (with a large value of the variable ",
 StyleBox["precision", "Code"],
 ") results in another dramatic increase in efficiency. "
}], "Text",
 CellChangeTimes->{{3.841146152779657*^9, 3.841146391589287*^9}, {
  3.9591768659489155`*^9, 
  3.959176896436281*^9}},ExpressionUUID->"8079c526-f3f5-454a-9fdf-\
b75030e5c5fd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Introducing Functions", "Section",
 CellChangeTimes->{{3.8395036798049245`*^9, 
  3.839503698388985*^9}},ExpressionUUID->"1983f635-b8a0-4e4a-8233-\
2212cd2d8580"],

Cell[TextData[{
 "In programming, a function allows us to give a name to a block of code, \
which we can call whenever we want to run the code. Here, we define the \
function firstFunc from Pseudocode 1.14 in the text. This function requires \
one parameter, ",
 StyleBox["x", "Code"],
 ". In the following code, the syntax ",
 StyleBox[":=", "Code"],
 " is Mathematica\[CloseCurlyQuote]s ",
 StyleBox["delayed assignment",
  FontSlant->"Italic"],
 " operator, which means that computation does not happen immediately when we \
define ",
 StyleBox["firstFunc", "Code"],
 ", but rather the computation happens each time ",
 StyleBox["firstFunc", "Code"],
 " is called. "
}], "Text",
 CellChangeTimes->{{3.839503777087242*^9, 3.8395038297131767`*^9}, 
   3.839503916561598*^9, {3.839505100925572*^9, 3.8395051237326956`*^9}, {
   3.846084991449078*^9, 3.846085006368198*^9}, 3.84608517634686*^9, {
   3.9591769375135384`*^9, 3.9591770917400856`*^9}, {3.9591774393575306`*^9, 
   3.959177473119604*^9}},ExpressionUUID->"23f3c983-3291-49b6-944d-\
92e47cb7e8ea"],

Cell[BoxData[
 RowBox[{
  RowBox[{"firstFunc", "[", "x_", "]"}], ":=", 
  RowBox[{
   SuperscriptBox["x", "2"], "+", "1"}]}]], "Input",
 CellChangeTimes->{{3.95917739534449*^9, 3.959177412445114*^9}},
 CellLabel->
  "In[159]:=",ExpressionUUID->"e819aca0-1991-d241-8272-96a9de35f06e"],

Cell[TextData[{
 "Now we can call our function with values of ",
 StyleBox["x", "Code"],
 ":"
}], "Text",
 CellChangeTimes->{{3.9591774760023556`*^9, 
  3.9591774890448227`*^9}},ExpressionUUID->"19198389-03f0-fe4f-8d4b-\
5fff8be69f87"],

Cell[BoxData[
 RowBox[{"firstFunc", "[", "3", "]"}]], "Input",
 CellChangeTimes->{{3.959177415224457*^9, 3.9591774173711586`*^9}},
 CellLabel->
  "In[160]:=",ExpressionUUID->"562dcf29-c9ce-0e42-9038-97b09c356e3c"],

Cell[BoxData[
 RowBox[{"firstFunc", "[", 
  RowBox[{"-", "5"}], "]"}]], "Input",
 CellChangeTimes->{{3.959177418799116*^9, 3.959177424314703*^9}},
 CellLabel->
  "In[161]:=",ExpressionUUID->"927f3259-7f85-4b4a-8570-c0fe90b91ce3"],

Cell[BoxData[
 RowBox[{"firstFunc", "[", "1.5", "]"}]], "Input",
 CellChangeTimes->{{3.959177493514448*^9, 3.959177495915304*^9}},
 CellLabel->
  "In[162]:=",ExpressionUUID->"ccceb948-a6bb-2540-9e0f-8f4e9541c6ce"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Modules and Runtime", "Section",
 CellChangeTimes->{{3.839673790347553*^9, 3.839673801474882*^9}, {
   3.8396740559518003`*^9, 3.839674057841525*^9}, 
   3.95917751798402*^9},ExpressionUUID->"6d968116-eebf-4ec7-aa01-\
acf992765277"],

Cell[TextData[{
 "In Mathematica, a ",
 StyleBox["Module", "Code"],
 " allows us to define a block of code with its own variables. This code can \
contain its own ",
 StyleBox["local",
  FontSlant->"Italic"],
 " variables that won\[CloseCurlyQuote]t conflict with variables outside of \
the ",
 StyleBox["Module", "Code"],
 ". The following ",
 StyleBox["Module", "Code"],
 " returns an approximation of \[Pi] computed with ",
 StyleBox["nMax", "Code"],
 " iterations, corresponding to Pseudocode 1.15 in the text."
}], "Text",
 CellChangeTimes->{{3.8396741790806627`*^9, 3.8396742113786173`*^9}, {
   3.8408988789712753`*^9, 3.840898884588173*^9}, {3.8408990811428947`*^9, 
   3.840899083054205*^9}, {3.8411468539873238`*^9, 3.84114688386322*^9}, {
   3.846085181400532*^9, 3.846085188717189*^9}, 3.846087315745379*^9, 
   3.8461610339840183`*^9, {3.9591775211593723`*^9, 
   3.9591776481490917`*^9}},ExpressionUUID->"a568b8f8-3773-4ed0-8701-\
6f1fbdd4e4a9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"approxPi", "[", "nMax_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"specify", " ", "local", " ", "variables"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"sideLength", "=", 
       RowBox[{"Sqrt", "[", "2", "]"}]}], ",", 
      RowBox[{"piValues", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", "nMax"}], "]"}]}], ",", "a", ",", " ", "b"}], "}"}],
     ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"main", " ", "loop"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Compute", " ", "a", " ", "and", " ", "b", " ", "values"}], 
       " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"a", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"1", "-", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"b", "=", 
         RowBox[{"1", "-", "a"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Compute", " ", "the", " ", "new", " ", "side", " ", "length", " ", 
          "and", " ", "perimeter"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"sideLength", "=", 
         RowBox[{"Simplify", "[", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            SuperscriptBox["b", "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"sideLength", "/", "2"}], ")"}], "2"]}], "]"}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"perimeter", " ", "=", " ", 
         RowBox[{
          SuperscriptBox["2", "n"], "*", " ", "sideLength"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Compute", " ", "the", " ", "approximation", " ", "to", " ", "pi"}], 
         " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "piValues", "\[LeftDoubleBracket]", "n", "\[RightDoubleBracket]"}], "=", 
         RowBox[{"perimeter", "/", "2"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"n", ",", "3", ",", "nMax"}], "}"}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "return", " ", "the", " ", "approximation", " ", "based", " ", "on", " ",
        "the", " ", "side", " ", "length"}], " ", "*)"}], 
     "\[IndentingNewLine]", "piValues"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.841146679597802*^9, 3.841146843759481*^9}, {
  3.841146896329348*^9, 3.841146922573247*^9}, {3.8460849385269938`*^9, 
  3.846084971914575*^9}, {3.846087324315477*^9, 3.846087380772869*^9}, {
  3.959177693926428*^9, 3.959177802980812*^9}},
 CellLabel->
  "In[168]:=",ExpressionUUID->"87d902c8-85a7-460c-bd93-4241a5aa2314"],

Cell["Now try out this Module:", "Text",
 CellChangeTimes->{{3.841146932273538*^9, 3.841146933699703*^9}, {
  3.9591777614504013`*^9, 
  3.959177764125387*^9}},ExpressionUUID->"c1c23ba3-830f-49ed-b2d3-\
6acac146cf58"],

Cell[BoxData[
 RowBox[{"approxPi", "[", "5", "]"}]], "Input",
 CellChangeTimes->{{3.8396743796723223`*^9, 3.83967440575309*^9}, {
   3.840898919354142*^9, 3.84089891974432*^9}, 3.9591777585310555`*^9},
 CellLabel->
  "In[169]:=",ExpressionUUID->"27e2dd54-02da-4724-a88d-58083264ea95"],

Cell[TextData[{
 "Next we will measure the runtime of our module. The following a simple \
function will help measure runtime. Note that runtime measurements may be \
inaccurate if we measure the runtime of the exact same calculation more than \
once, since Mathematica remembers and recalls previously-computed values. To \
get accurate runtime results, we should call ",
 StyleBox["ClearSystemCache[]", "Code"],
 " before measuring runtime so that we actually get the runtime of the \
calculation, not the runtime of Mathematica recalling a previous calculation."
}], "Text",
 CellChangeTimes->{{3.8396742225140696`*^9, 3.839674229482288*^9}, {
  3.9591778204504356`*^9, 3.959177834027561*^9}, {3.959177993507223*^9, 
  3.9591780751152935`*^9}},ExpressionUUID->"0893666c-0cb8-4685-bb6c-\
f8b70ffd90a9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"timeIt", "[", "nMax_", "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"ClearSystemCache", "[", "]"}], ";", 
    RowBox[{
     RowBox[{"Timing", "[", 
      RowBox[{"approxPi", "[", "nMax", "]"}], "]"}], "\[LeftDoubleBracket]", 
     "1", "\[RightDoubleBracket]"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.8396742307151012`*^9, 3.8396742510330715`*^9}, {
  3.959177969572384*^9, 3.9591779759564*^9}},
 CellLabel->
  "In[183]:=",ExpressionUUID->"d4d0bed1-7707-4667-9928-63f7fbc7bf1d"],

Cell[TextData[{
 "Now we can call our ",
 StyleBox["timeIt", "Code"],
 " function. "
}], "Text",
 CellChangeTimes->{{3.9591779259129086`*^9, 3.959177958943796*^9}, 
   3.959177992479141*^9},ExpressionUUID->"631b13ac-ded0-6b44-9080-\
790e134fca7b"],

Cell[BoxData[
 RowBox[{"timeIt", "[", "3", "]"}]], "Input",
 CellChangeTimes->{{3.9591778682261047`*^9, 3.959177870316244*^9}, {
  3.9591779174665356`*^9, 3.9591779180802593`*^9}, {3.95917797947254*^9, 
  3.9591779798676224`*^9}},
 CellLabel->
  "In[184]:=",ExpressionUUID->"1fed1ee5-8610-024b-aab8-059f64fbd49e"],

Cell[BoxData[
 RowBox[{"timeIt", "[", "10", "]"}]], "Input",
 CellChangeTimes->{{3.959177891362871*^9, 3.95917792069154*^9}, {
  3.9591779834841423`*^9, 3.959177983607704*^9}},
 CellLabel->
  "In[185]:=",ExpressionUUID->"528c5d63-4542-ee48-9c19-56ee73176ead"],

Cell[BoxData[
 RowBox[{"timeIt", "[", "15", "]"}]], "Input",
 CellChangeTimes->{{3.9591778793971634`*^9, 3.9591779097081776`*^9}, {
  3.9591779868452663`*^9, 3.9591779869973354`*^9}},
 CellLabel->
  "In[186]:=",ExpressionUUID->"fe20de96-3d5f-7f49-9dab-bebd7bc26cde"]
}, Open  ]]
}, Open  ]]
},
