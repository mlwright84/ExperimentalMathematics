Cell[TextData[{
 "Now we can compute the accuracy of each approximation using the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["log", "10"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0ce9bd33-0e18-7d42-9d48-138e50d4c37b"],
 " method described in the text. "
}], "Text",
 CellChangeTimes->{{3.8413251038741074`*^9, 3.841325119521617*^9}, {
  3.9592100271120663`*^9, 3.959210080088194*^9}, {3.963323031965376*^9, 
  3.9633230333973503`*^9}},ExpressionUUID->"ca768e54-8877-4c8f-b6c6-\
9837aa93a74a"],

