 RowBox[{"accuracy", "=", 
  RowBox[{"N", "[", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"Log", "[", 
      RowBox[{"10", ",", 
       RowBox[{"Pi", "-", "piVals"}]}], "]"}]}], ",", "3"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8395122206267576`*^9, 3.839512223718599*^9}, {
