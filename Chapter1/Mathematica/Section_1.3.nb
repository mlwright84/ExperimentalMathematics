Cell[TextData[{
 "Now let's compute partial sums using more terms. First, \
we\[CloseCurlyQuote]ll make a list of values of ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "d77f9c1b-9d8d-4a89-a94b-f2c8e6d7f61b"],
 ", each giving the number of terms for a partial sum that we will compute."
}], "Text",
 CellChangeTimes->{{3.8413249718942575`*^9, 
  3.8413250426708865`*^9}},ExpressionUUID->"80c0d15d-ce6e-412c-b145-\
8c83145a296b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"mVals", "=", 
  RowBox[{"Range", "[", 
   RowBox[{"100", ",", "1000", ",", "100"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8395120883461947`*^9, 3.8395120944893494`*^9}, {
   3.8395121245717*^9, 3.83951212755344*^9}, 3.8409004883375597`*^9, 
   3.840901154866351*^9, 3.8413249424766617`*^9, {3.9592099827301064`*^9, 
