Cell[TextData[{
 "Accompanies Section 1.3 of ",
 StyleBox["Experimental Mathematics: A Computational Perspective",
  FontSlant->"Italic"],
 " by Matthew P. Richey and Matthew L. Wright"
}], "Subtitle",
 CellChangeTimes->{{3.846071946694004*^9, 3.846071951019271*^9}, {
   3.8463287390321293`*^9, 3.846328739944585*^9}, {3.959178387747711*^9, 
   3.9591784428734837`*^9}, {3.9591784977036953`*^9, 3.9591785089527645`*^9}, 
   3.959179795914255*^9, 3.9592090383970146`*^9},
 TextAlignment->Center,
 FontSize->18,ExpressionUUID->"668e3ae5-5f86-464a-8884-35fc88646704"],

Cell[CellGroupData[{

Cell["Computing a Partial Sum", "Section",
 CellChangeTimes->{{3.8413232022103777`*^9, 3.841323209755287*^9}, {
  3.96334846171813*^9, 
  3.9633484629210033`*^9}},ExpressionUUID->"09f37fe6-2580-40b6-9c43-\
e34c703e0485"],

Cell[TextData[{
 "In this notebook we compute approximations to \[Pi] using partial sums of \
the Taylor series for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"arctan", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "e01495f6-5305-4ed7-b8b3-234cd841ff86"],
 ". Specifically, for the infinite series"
}], "Text",
 CellChangeTimes->{{3.841322707308872*^9, 3.8413227580389824`*^9}, {
   3.8413228447573256`*^9, 3.8413228842150264`*^9}, {3.8461554664598637`*^9, 
   3.8461554722449408`*^9}, {3.846156176812048*^9, 3.846156180323432*^9}, 
   3.959178594952732*^9},ExpressionUUID->"77c10498-d7e6-4a30-8559-\
6a8f549929af"],

Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       FractionBox["\[Pi]", "4"], "\[LongEqual]", "1", "-", 
       FractionBox["1", "3"], "+", 
       FractionBox["1", "5"], "-", 
       FractionBox["1", "7"], "+", "\[CenterEllipsis]", "\[LongEqual]", 
       UnderoverscriptBox["\[Sum]", 
        RowBox[{
          StyleBox["k", "TI"], "\[LongEqual]", "1"}], "\[Infinity]", 
        LimitsPositioning -> True], 
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", "-1", ")"}], 
         RowBox[{
           StyleBox["k", "TI"], "+", "1"}]], 
        RowBox[{"2", 
          StyleBox["k", "TI"], "-", "1"}]]}], TraditionalForm], 
   "errors" -> {}, "input" -> 
   "\\frac{\\pi}{4}=1-\\frac{1}{3}+\\frac{1}{5}-\\frac{1}{7}+\\cdots=\\sum_{k=\
1}^\\infty \\frac{(-1)^{k+1}}{2k-1}", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellChangeTimes->{
  3.8461558983490477`*^9, {3.846156185683457*^9, 3.846156190945718*^9}},
 TextAlignment->Center,ExpressionUUID->"717fbc1d-77f9-4acc-9c1b-6fe8462a53fe"],

Cell["the partial sum is a finite sum ", "Text",
 CellChangeTimes->{{3.8413229013283997`*^9, 3.8413229918786154`*^9}, {
  3.8461554776641827`*^9, 3.846155489130453*^9}, {3.846155554659157*^9, 
  3.846155570034863*^9}, {3.846155809061406*^9, 3.846155833872467*^9}, {
  3.846156046991428*^9, 
  3.8461560474595413`*^9}},ExpressionUUID->"10f1c644-9f41-4a26-bf15-\
9ead6f9566c3"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        FractionBox["\[Pi]", "4"], "\[TildeTilde]", "1", "-", 
        FractionBox["1", "3"], "+", 
        FractionBox["1", "5"], "-", 
        FractionBox["1", "7"], "+", "\[CenterEllipsis]", "\[LongEqual]", 
        UnderoverscriptBox["\[Sum]", 
         RowBox[{
           StyleBox["k", "TI"], "\[LongEqual]", "1"}], 
         StyleBox["m", "TI"], LimitsPositioning -> True], 
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", "-1", ")"}], 
          RowBox[{
            StyleBox["k", "TI"], "+", "1"}]], 
         RowBox[{"2", 
           StyleBox["k", "TI"], "-", "1"}]]}], TraditionalForm], 
    "errors" -> {}, "input" -> 
    "\\frac{\\pi}{4} \\approx \
1-\\frac{1}{3}+\\frac{1}{5}-\\frac{1}{7}+\\cdots=\\sum_{k=1}^m\\frac{(-1)^{k+\
1}}{2k-1}", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"26e75ce0-56f8-413e-bd09-34534cc97826"]], \
"Text",
 CellChangeTimes->{{3.8413229013283997`*^9, 3.8413229918786154`*^9}, {
   3.8461554776641827`*^9, 3.846155489130453*^9}, {3.846155554659157*^9, 
   3.846155570034863*^9}, {3.846155809061406*^9, 3.846155821059145*^9}, 
   3.9591786086677723`*^9},
 TextAlignment->Center,ExpressionUUID->"1306dcc8-29bd-4105-98b5-cbd3d2f304bc"],

Cell[TextData[{
 "for some value maximum value ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "26f49f4c-48f8-2f4c-9ee0-3cb9bff855d6"],
 "."
}], "Text",
 CellChangeTimes->{{3.8413229013283997`*^9, 3.8413229918786154`*^9}, {
  3.8461554776641827`*^9, 3.846155489130453*^9}, {3.8461555593422947`*^9, 
  3.84615560257649*^9}, {3.8461556347312326`*^9, 3.846155635331736*^9}, {
  3.846156089616205*^9, 3.846156094750436*^9}, {3.9591786168292522`*^9, 
  3.9591786341297836`*^9}},ExpressionUUID->"20544a17-8c72-4df1-88f2-\
8366cbd8f336"],

Cell[TextData[{
 "To compute this partial sum, we add up the first ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "ea99e6d3-00a3-c443-8752-69390c3717a9"],
 " terms of this series using a loop with an accumulator. Our accumulator, \
the variable ",
 StyleBox["acc", "Code"],
 " in the code below, stores the running total as we add up the terms."
}], "Text",
 CellChangeTimes->{{3.8413229013283997`*^9, 3.8413229918786154`*^9}, {
  3.8461554776641827`*^9, 3.846155489130453*^9}, {3.8461555593422947`*^9, 
  3.84615560257649*^9}, {3.8461556347312326`*^9, 3.846155635331736*^9}, {
  3.846156089616205*^9, 3.846156094750436*^9}, {3.9591786168292522`*^9, 
  3.9591786237930984`*^9}},ExpressionUUID->"dde95349-3c30-3a43-a739-\
fb33a0ce5ea4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"m", "=", "50"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "number", " ", "of", " ", "terms", " ", "to", " ", "add", " ", "up"}], " ",
    "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"acc", "=", "0"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"accumulator", ",", " ", 
    RowBox[{"initialized", " ", "to", " ", "zero"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Uncomment", " ", "the", " ", "following", " ", "line", " ", "to", " ", 
    "print", " ", "out", " ", "the", " ", "values", " ", "that", " ", "we", " ",
     "add", " ", "ot", " ", "the", " ", 
    RowBox[{"accumulator", ".", " ", "Remember"}], " ", "that", " ", "print", 
    " ", "statements", " ", "inside", " ", "of", " ", "a", " ", "loop", " ", 
    "are", " ", "helpful", " ", "for", " ", 
    RowBox[{"debuggin", "!"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"i", "+", "1"}], ")"}]], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "i"}], "-", "1"}], ")"}]}], "]"}], ";"}], "  ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"acc", "+=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"i", "+", "1"}], ")"}]], "/", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", "i"}], "-", "1"}], ")"}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"i", ",", "1", ",", "m"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.8395117057205486`*^9, 3.8395117062884197`*^9}, {
  3.8413229947986927`*^9, 3.841323073066672*^9}, {3.9591786616352463`*^9, 
  3.959178673746109*^9}, {3.9592091691150723`*^9, 3.9592092051459217`*^9}, {
  3.959209337816332*^9, 
  3.959209373204115*^9}},ExpressionUUID->"48de747a-83da-4baf-bd49-\
f661a36a3a2e"],

Cell[TextData[{
 "The value ",
 StyleBox["4\[Times]acc", "Code"],
 " is our approximation of \[Pi]. If we simply print this number, we\
\[CloseCurlyQuote]ll get a big fraction:"
}], "Text",
 CellChangeTimes->{{3.8413230765928583`*^9, 3.841323146629843*^9}, {
  3.8413240277557974`*^9, 3.841324046031618*^9}, {3.959178691294861*^9, 
  3.9591787074685097`*^9}},ExpressionUUID->"8a32801e-286b-42a7-b933-\
f437d664e17d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"4", "*", "acc"}]], "Input",
 CellChangeTimes->{{3.841324030445797*^9, 3.841324031537257*^9}},
 CellLabel->
  "In[190]:=",ExpressionUUID->"f203d9e9-8083-48ab-a594-d14adac0a125"],

Cell[BoxData[
 FractionBox["3400605476464206445954873476681150352328", 
  "1089380862964257455695840764614254743075"]], "Output",
 CellChangeTimes->{3.959178762639036*^9},
 CellLabel->
  "Out[190]=",ExpressionUUID->"f8528762-528c-2d40-a15f-86de41d198f3"]
}, Open  ]],

Cell["\<\
We can also convert the result to a decimal number with any desired amount of \
digits. Here, we\[CloseCurlyQuote]ll ask for 20 digits:\
\>", "Text",
 CellChangeTimes->{{3.8413230765928583`*^9, 3.841323146629843*^9}, {
   3.8413240505998373`*^9, 3.8413240905137777`*^9}, 
   3.959178769145321*^9},ExpressionUUID->"c5458984-f7a1-463f-aad1-\
938907cda3d2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{
   RowBox[{"4", "*", "acc"}], ",", " ", "20"}], "]"}]], "Input",
 CellChangeTimes->{{3.8413230997377305`*^9, 3.841323115299159*^9}, {
  3.8413240609408026`*^9, 3.84132406134724*^9}},
 CellLabel->
  "In[191]:=",ExpressionUUID->"cd6e2872-57c5-4acf-bd32-01d854a69860"],

Cell[BoxData["3.12159465259101047851318297430949243292`20."], "Output",
 CellChangeTimes->{3.9591787705411263`*^9},
 CellLabel->
  "Out[191]=",ExpressionUUID->"8c768762-e111-594a-811b-53645ac8b710"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Analyzing Accuracy", "Section",
 CellChangeTimes->{{3.8413232336747007`*^9, 3.8413232385957127`*^9}, 
   3.9592094327265663`*^9},ExpressionUUID->"9b2f29b5-619a-4036-ba03-\
542f60fee4e4"],

Cell[TextData[{
 "Let's find out how the accuracy of the approximation depends on the number \
of terms and recreate Table 1.2 in the text. For this, it is convenient to \
define a function (a ",
 StyleBox["Module", "Code"],
 ", in Mathematica) that returns the ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "52e1de8c-3347-43de-848b-26c7ba1b6981"],
 "-term partial sum of the Madhava series."
}], "Text",
 CellChangeTimes->{{3.841323255004768*^9, 3.841323281358128*^9}, {
  3.8413233485696664`*^9, 3.8413233874242034`*^9}, {3.841323454195345*^9, 
  3.841323455912949*^9}, {3.9592099671581135`*^9, 
  3.9592099737611637`*^9}},ExpressionUUID->"b92844a3-7c39-4eae-b40d-\
f9add6acdd71"],

Cell["\<\
It's important to consider the number type that the computer will use for \
this calculation. In the previous calculation we used fractions (exact \
values), but this may be rather slow if we want to add a large number of \
terms. The fastest option is to use floating-point numbers throughout the \
computation, but this provides a maximum of about 16 decimal digits and \
suffers from round-off error in repeated addition operations. A good middle \
ground is to use a large, but fixed, number of decimal digits throughout the \
calculation. \
\>", "Text",
 CellChangeTimes->{{3.8413234581935525`*^9, 3.841323495058158*^9}, {
   3.8413239440722575`*^9, 3.841323946336823*^9}, {3.841324006500451*^9, 
   3.841324009212932*^9}, {3.841324099276164*^9, 3.841324252006236*^9}, {
   3.841324297372759*^9, 3.841324300195091*^9}, {3.841324816007837*^9, 
   3.8413248769072113`*^9}, {3.959209484965479*^9, 3.9592095660195217`*^9}, 
   3.9592096015378265`*^9},ExpressionUUID->"dd744c9e-96de-4965-92ae-\
bd760e738bac"],

Cell[TextData[{
 "In the code below, we use Mathematica\[CloseCurlyQuote]s ",
 StyleBox["N", "Code"],
 " function to specify that numbers are stored with 100 decimal digits of \
precision. This code is similar to Pseudocode 1.19 in the text."
}], "Text",
 CellChangeTimes->{{3.8413234581935525`*^9, 3.841323495058158*^9}, {
  3.8413239440722575`*^9, 3.841323946336823*^9}, {3.841324006500451*^9, 
  3.841324009212932*^9}, {3.841324099276164*^9, 3.841324252006236*^9}, {
  3.841324297372759*^9, 3.841324300195091*^9}, {3.841324816007837*^9, 
  3.8413248769072113`*^9}, {3.959209484965479*^9, 3.9592095660195217`*^9}, {
  3.959209604470703*^9, 
  3.9592096196207047`*^9}},ExpressionUUID->"6aa05103-d338-b447-b9a3-\
021a41f946b3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"madhavaSum", "[", "m_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"acc", "=", "0"}], "}"}], ",", " ", 
    RowBox[{"(*", " ", 
     RowBox[{
     "initialize", " ", "the", " ", "accumulator", " ", "as", " ", "a", " ", 
      "local", " ", "variable"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"acc", "+=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"-", "1"}], ")"}], 
            RowBox[{"(", 
             RowBox[{"i", "+", "1"}], ")"}]], "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "i"}], "-", "1"}], ")"}]}], ",", "100"}], "]"}]}], ",",
        " ", 
       RowBox[{"(*", " ", 
        RowBox[{"note", " ", "100", " ", "decimal", " ", "digits"}], " ", 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "m"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"4", "*", "acc"}]}]}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"return", " ", "value"}], " ", "*)"}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.8395117481274405`*^9, 3.8395117837451024`*^9}, 
   3.8395118951893153`*^9, {3.8409019540956726`*^9, 3.840901959633932*^9}, {
   3.8409020491565027`*^9, 3.8409020739854345`*^9}, {3.8409021879840636`*^9, 
   3.840902201790405*^9}, {3.8409022999235992`*^9, 3.840902302377553*^9}, {
   3.841323290896073*^9, 3.84132333095002*^9}, {3.841324323050247*^9, 
   3.8413243522975655`*^9}, {3.8413248794112835`*^9, 
   3.8413249008985977`*^9}, {3.959179039368616*^9, 3.959179043955675*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"a173c2b1-8352-4921-8936-c22bb3dcc401"],

