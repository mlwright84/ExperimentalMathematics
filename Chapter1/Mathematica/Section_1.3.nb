 CellLabel->"In[7]:=",ExpressionUUID->"2f135b93-a0f7-4032-bd92-e5fc9e1eedf6"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "100", ",", "200", ",", "300", ",", "400", ",", "500", ",", "600", ",", 
   "700", ",", "800", ",", "900", ",", "1000"}], "}"}]], "Output",
 CellChangeTimes->{3.8461568256063347`*^9, 3.9592098649209385`*^9, 
  3.95920999285334*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"4d99466d-0240-8746-87aa-e323da127487"]
}, Open  ]],

Cell[TextData[{
 "Now we will compute the partial sums for each value of ",
 StyleBox["m",
  FontWeight->"Bold"],
 ". We\[CloseCurlyQuote]ll print each partial sum to 20 decimal digits. "
}], "Text",
 CellChangeTimes->{{3.8413250475080786`*^9, 3.8413250790173273`*^9}, {
   3.846156792330616*^9, 3.846156847719998*^9}, 
