Cell[BoxData[{
 RowBox[{
  RowBox[{"piVals", "=", 
   RowBox[{"Map", "[", 
    RowBox[{"madhavaSum", ",", "mVals"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"N", "[", 
  RowBox[{"piVals", ",", "20"}], "]"}]}], "Input",
 CellChangeTimes->{{3.839512151244581*^9, 3.8395121589121456`*^9}, {
