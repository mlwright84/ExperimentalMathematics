Cell[TextData[{
 "If the accuracy doubles with each iteration, then the plot above has a \
shape like ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]],ExpressionUUID->
  "1e3d8059-50f5-488f-b81e-f7034c660fb9"],
 ". In this case, a ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["log", "2"], TraditionalForm]],ExpressionUUID->
  "0ee86523-2edf-478e-b7fc-f5ee0a8564a9"],
 " transform of the data points should result in a linear plot. Let\
\[CloseCurlyQuote]s plot the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["log", "2"], TraditionalForm]],ExpressionUUID->
  "8fc378b7-6018-4030-a505-c8506d106374"],
 " of each data point:"
}], "Text",
