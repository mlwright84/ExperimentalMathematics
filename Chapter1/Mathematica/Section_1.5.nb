Notebook[{

Cell[CellGroupData[{
Cell["Further Series and Iterative Methods", "Title",
 CellChangeTimes->{{3.841322393248269*^9, 3.841322396303512*^9}, {
  3.8414091027463083`*^9, 3.8414091128745394`*^9}, {3.8414178590463285`*^9, 
  3.841417868779046*^9}},
 TextAlignment->Center,ExpressionUUID->"269014ff-3d22-4340-8c4e-3d88cbc531a7"],

Cell[TextData[{
 "Accompanies Section 1.5 of ",
 StyleBox["Experimental Mathematics: A Computational Perspective",
  FontSlant->"Italic"],
 " by Matthew P. Richey and Matthew L. Wright"
}], "Subtitle",
 CellChangeTimes->{{3.846071946694004*^9, 3.846071951019271*^9}, {
   3.8463287390321293`*^9, 3.846328739944585*^9}, {3.959178387747711*^9, 
   3.9591784428734837`*^9}, {3.9591784977036953`*^9, 3.9591785089527645`*^9}, 
   3.959179795914255*^9, 3.9592090383970146`*^9, 3.959210620985943*^9},
 TextAlignment->Center,
 FontSize->18,ExpressionUUID->"6aa8db15-9431-a847-9bbc-110311219f57"],

Cell[CellGroupData[{

Cell["Ramanujan\[CloseCurlyQuote]s Formula", "Section",
 CellChangeTimes->{{3.8413232022103777`*^9, 3.841323209755287*^9}, {
   3.8414091563490124`*^9, 3.841409162398589*^9}, {3.841417900963851*^9, 
   3.8414179038218293`*^9}, {3.963324212496769*^9, 3.963324213190874*^9}, 
   3.963348483582964*^9},ExpressionUUID->"70f4067c-fd79-45d7-a9f5-\
cf0ccf12c339"],

Cell["\<\
Here is Ramanujan\[CloseCurlyQuote]s formula, from equation (1.12) in the \
text:\
\>", "Text",
 CellChangeTimes->{{3.841322707308872*^9, 3.8413227580389824`*^9}, {
  3.8413228447573256`*^9, 3.8413228842150264`*^9}, {3.841409195233779*^9, 
  3.8414092066248026`*^9}, {3.841417956494523*^9, 3.8414179639540014`*^9}, {
  3.96332421997336*^9, 
  3.9633242273675594`*^9}},ExpressionUUID->"70124716-a53b-437a-8e16-\
e1c5d9df3a75"],

Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        FractionBox["1", "\[Pi]"], "\[LongEqual]", 
        FractionBox[
         RowBox[{"2", 
           SqrtBox["2"]}], "9801"], 
        UnderoverscriptBox["\[Sum]", 
         RowBox[{
           StyleBox["k", "TI"], "\[LongEqual]", "0"}], "\[Infinity]", 
         LimitsPositioning -> True], 
        FractionBox[
         RowBox[{
           RowBox[{"(", 
             RowBox[{"4", 
               StyleBox["k", "TI"]}], ")"}], "!", 
           RowBox[{"(", 
             RowBox[{"1103", "+", "26390", 
               StyleBox["k", "TI"]}], ")"}]}], 
         RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
              RowBox[{
                StyleBox["k", "TI"], "!"}], ")"}], "4"], 
           SuperscriptBox["396", 
            RowBox[{"4", 
              StyleBox["k", "TI"]}]]}]]}], TraditionalForm], "errors" -> {}, 
    "input" -> 
    "\\frac{1}{\\pi}=\\frac{2\\sqrt{2}}{9801}\\sum_{k=0}^{\\infty}\\frac{(4k)!\
(1103+26390k)}{(k!)^4 396^{4k}}", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], TraditionalForm]], "Text",
 CellChangeTimes->{{3.7299845905724764`*^9, 3.729984597573049*^9}, {
  3.72998539218108*^9, 3.7299854046660323`*^9}, {3.841417966645011*^9, 
  3.8414179673143816`*^9}, {3.84625324898526*^9, 3.84625326012041*^9}},
 TextAlignment->Center,ExpressionUUID->"aeeb908f-1a9f-4b11-9ce7-8d401359082f"],

Cell[TextData[{
 "We will write a module that adds up ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "+", "1"}], TraditionalForm]],ExpressionUUID->
  "77741e3c-2055-4c3d-a190-eb9ac5bf88fd"],
 " terms (indexes ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "0"}], ",", "...", ",", "m"}], TraditionalForm]],
  ExpressionUUID->"7a50a4cf-dce9-4030-b8ea-46ba2b6a58b7"],
 ") of this sum. Since the formula gives an approximation to ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", "\[Pi]"], TraditionalForm]],ExpressionUUID->
  "db4a221e-c328-41ec-b2e7-78e2ee73d55a"],
 ", we must invert the result to obtain an approximation to \[Pi]. The \
following module includes a print statement that prints each term of the sum, \
which is helpful for testing the code and confirming that it works as \
expected."
}], "Text",
 CellChangeTimes->{{3.84141799902191*^9, 3.8414180748114023`*^9}, {
  3.8414181702186584`*^9, 3.841418264681366*^9}, {3.8414184465470915`*^9, 
  3.8414184483409443`*^9}, {3.963324249070574*^9, 
  3.9633242778908997`*^9}},ExpressionUUID->"a15e0e06-6243-4fd2-a6b1-\
97db4e5f95df"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ramanujan", "[", "m_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"total", "=", "0"}], ",", " ", "val"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"val", "=", 
         FractionBox[
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"4", "k"}], ")"}], "!"}], 
           RowBox[{"(", 
            RowBox[{"1103", "+", 
             RowBox[{"26390", "k"}]}], ")"}]}], 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"k", "!"}], ")"}], "^", "4"}], "*", 
           RowBox[{"396", "^", 
            RowBox[{"(", 
             RowBox[{"4", "k"}], ")"}]}]}]]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", "val", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"total", "+=", "val"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", "m"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"total", "*=", 
      RowBox[{"2", 
       RowBox[{
        RowBox[{"Sqrt", "[", "2", "]"}], "/", "9801"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"1", "/", "total"}]}]}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"return", " ", "value"}], " ", "*)"}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.729984611811432*^9, 3.7299848057182903`*^9}, {
   3.7299879801349797`*^9, 3.729987982733632*^9}, {3.7299880160483723`*^9, 
   3.729988017648691*^9}, {3.7589607516458077`*^9, 3.758960776537917*^9}, {
   3.8414179921190777`*^9, 3.841417994069768*^9}, {3.8414180812748213`*^9, 
   3.8414181197632027`*^9}, {3.8462542023502817`*^9, 3.846254232590704*^9}, {
   3.9633242808527927`*^9, 3.963324282469494*^9}, 
   3.9633243465312138`*^9},ExpressionUUID->"909054f7-727b-41ea-872b-\
bab94557d669"],

Cell[TextData[{
 "Try it with just one term (",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d4526a2b-6b55-a946-b857-d090daeb5414"],
 "). Note that the code prints ",
 Cell[BoxData[
  FormBox["1103", TraditionalForm]],ExpressionUUID->
  "e2d89c60-e735-4e43-a4eb-7ba1a2619346"],
 " since this is the value of the first term."
}], "Text",
 CellChangeTimes->{{3.7299848261339083`*^9, 3.7299848302029696`*^9}, {
  3.7299849040598893`*^9, 3.7299849158438244`*^9}, {3.7910329203651047`*^9, 
