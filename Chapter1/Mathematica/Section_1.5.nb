Cell[CellGroupData[{

Cell["Accuracy", "Subsection",
 CellChangeTimes->{{3.7911193501443014`*^9, 3.7911193608732667`*^9}, {
  3.8405777980308285`*^9, 
  3.840577799096016*^9}},ExpressionUUID->"ce5d83c0-9bc2-4f83-b6b7-\
12d2d0adfabf"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s compute the accuracy of each approximation using the \
",
 Cell[BoxData[
  FormBox[
   SubscriptBox["log", "10"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a1442ca5-d3a3-f044-a9e2-9e9473f206aa"],
 " method. Ramanujan\[CloseCurlyQuote]s method produces so many correct \
digits that we need to tell Mathematica to use extra precision for this \
calculation. (Otherwise, Mathematica will show an \
\[OpenCurlyDoubleQuote]Internal precision limit reached\
\[CloseCurlyDoubleQuote] message.)"
}], "Text",
 CellChangeTimes->{{3.8405779379996586`*^9, 3.8405779413003855`*^9}, {
  3.841418608918831*^9, 3.8414186817007074`*^9}, {3.9633244965237637`*^9, 
  3.9633245011335564`*^9}, {3.963324533758013*^9, 
  3.963324563638546*^9}},ExpressionUUID->"7b53e712-9f5b-446c-8410-\
c17506b69f8b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"accuracyRamanujan", "=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"$MaxExtraPrecision", "=", "1000"}], "}"}], ",", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"Log", "[", 
        RowBox[{"10", ",", 
         RowBox[{"Abs", "[", 
          RowBox[{"Pi", "-", "piValues"}], "]"}]}], "]"}]}], ",", "5"}], 
     "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.840577826300785*^9, 3.840577827991361*^9}, {
   3.840577886346586*^9, 3.840577897637684*^9}, 3.9633245129285564`*^9},
 CellLabel->"In[35]:=",ExpressionUUID->"b6c28a09-3786-499f-b19b-d5285f1c76f9"],

