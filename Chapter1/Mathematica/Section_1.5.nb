Cell["\<\
It looks like our code works. Now we can remove the print statement and run \
the code with more terms. The following copy of the module has the print \
statement commented out.\
\>", "Text",
 CellChangeTimes->{{3.8414183532180867`*^9, 3.841418353827959*^9}, {
  3.8414183925049505`*^9, 3.841418484359305*^9}, {3.963324378036068*^9, 
  3.9633243923825207`*^9}},ExpressionUUID->"8be6892e-78af-4ffb-b0b2-\
530e77c4d5fe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ramanujan", "[", "m_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"total", "=", "0"}], ",", " ", "val"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"val", "=", 
         FractionBox[
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"4", "k"}], ")"}], "!"}], 
           RowBox[{"(", 
            RowBox[{"1103", "+", 
             RowBox[{"26390", "k"}]}], ")"}]}], 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"k", "!"}], ")"}], "^", "4"}], "*", 
           RowBox[{"396", "^", 
            RowBox[{"(", 
             RowBox[{"4", "k"}], ")"}]}]}]]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Print", "[", "val", "]"}], ";"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"total", "+=", "val"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", "m"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"total", "*=", 
      RowBox[{"2", 
       RowBox[{
        RowBox[{"Sqrt", "[", "2", "]"}], "/", "9801"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"1", "/", "total"}]}]}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"return", " ", "value"}], " ", "*)"}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.729984611811432*^9, 3.7299848057182903`*^9}, {
  3.7299879801349797`*^9, 3.729987982733632*^9}, {3.7299880160483723`*^9, 
