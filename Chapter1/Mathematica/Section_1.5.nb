Cell[TextData[{
 "It looks like we have a lot of correct digits of \[Pi] after just a few \
iterations! Let\[CloseCurlyQuote]s compute the accuracy of each \
approximation. We\[CloseCurlyQuote]ll use the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["log", "10"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4bc400e3-f06c-1e47-a602-c00712a0c74b"],
 " method as usual. We also need to tell Mathematica to use extra digits of \
precision for this calculation."
}], "Text",
 CellChangeTimes->{{3.841419125179473*^9, 3.8414191693365717`*^9}, {
  3.9633250065021915`*^9, 
  3.9633250079935875`*^9}},ExpressionUUID->"028b2369-1fe0-4011-805a-\
989d93c1060f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"accuracySalminBrent", "=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"$MaxExtraPrecision", "=", "10000"}], "}"}], ",", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"Log", "[", 
        RowBox[{"10", ",", 
         RowBox[{"Abs", "[", 
          RowBox[{"Pi", "-", "piValues"}], "]"}]}], "]"}]}], ",", "5"}], 
     "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.840627326804569*^9, 3.840627338204591*^9}, 
   3.8406333137159176`*^9, {3.840633355149233*^9, 3.8406333558507137`*^9}, {
