Cell["\<\
It appears that the Ramanujan algorithm adds about 8 digits of accuracy for \
each additional term of the sum.\
\>", "Text",
 CellChangeTimes->{{3.846257813366954*^9, 3.8462578453030376`*^9}, {
  3.9633246248238945`*^9, 
  3.963324630194542*^9}},ExpressionUUID->"47814197-8966-4493-b331-\
4569e03ed905"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Salamin-Brent Algorithm", "Section",
 CellChangeTimes->{{3.8414187690095916`*^9, 3.841418777586108*^9}, {
   3.963324646163233*^9, 3.9633246502109184`*^9}, 
   3.9633484811214943`*^9},ExpressionUUID->"e5e7fd92-d892-4308-a4a3-\
f0997622762c"],

Cell[TextData[{
 "The following module implements Algorithm 1.23 in the text. \nFirst we \
initialize the values ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "0"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "ba906a29-5dfa-46b7-86fa-1d4deae6fdd1"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "0"], "=", 
    FractionBox["1", 
     RowBox[{"\[Sqrt]", "2"}]]}], TraditionalForm]],ExpressionUUID->
  "d58bc9b4-5f5d-4d86-ad2e-a62be6f641d2"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", "0"], "=", 
    FractionBox["1", "2"]}], TraditionalForm]],ExpressionUUID->
  "f837f32e-89b1-44ae-ad14-d86d91aa7404"],
 ". \nThen iterate the following steps for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", "2", ",", "...", ",", "m"}], 
   TraditionalForm]],ExpressionUUID->"9d3c6521-a060-46cb-9376-173eb42d37c4"],
 ":\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "k"], "=", 
    FractionBox[
     RowBox[{
      SubscriptBox["a", 
       RowBox[{"k", "-", "1"}]], "+", 
      SubscriptBox["b", 
       RowBox[{"k", "-", "1"}]]}], "2"]}], TraditionalForm]],ExpressionUUID->
  "4a684bf4-6013-4338-8365-143e269e9678"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "k"], "=", 
    RowBox[{"\[Sqrt]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["a", 
        RowBox[{"k", "-", "1"}]], 
       SubscriptBox["b", 
        RowBox[{"k", "-", "1"}]]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"ff673a97-e49e-447e-bdfa-909f5c3c8fab"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", "k"], "=", 
    RowBox[{
     SubscriptBox["s", 
      RowBox[{"k", "-", "1"}]], "-", 
     RowBox[{
      SuperscriptBox["2", "k"], 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         SubscriptBox["a", "k"], "2"], "-", 
        SuperscriptBox[
         SubscriptBox["b", "k"], "2"]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"f4c92eeb-5440-4eea-922e-94135d720775"],
 ",\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "k"], "=", 
    FractionBox[
     RowBox[{"2", 
      SuperscriptBox[
       SubscriptBox["a", "k"], "2"]}], 
     SubscriptBox["s", "k"]]}], TraditionalForm]],ExpressionUUID->
  "6f9328fd-9b00-4c1f-b9f6-b787df820764"],
 ". \nThe value ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "m"], TraditionalForm]],ExpressionUUID->
  "9e6c83b6-0011-4aca-b245-d1cb0df5d5df"],
 " gives an approximation to \[Pi].\nNote that the following code uses \
indexed variables instead of the subscripted variables that appear in \
Algorithm 1.23 in the text."
}], "Text",
 CellChangeTimes->{{3.7299874502858953`*^9, 3.7299876759055996`*^9}, {
  3.841418851297614*^9, 3.8414189404620934`*^9}, {3.9633246625582294`*^9, 
  3.9633247220120316`*^9}, {3.963324783405279*^9, 
  3.9633248329519463`*^9}},ExpressionUUID->"d3fee6ef-67ec-4fba-9dec-\
414379707e3f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"salaminBrent", "[", "m_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"local", " ", 
     RowBox[{"variables", ":", " ", 
      RowBox[{
      "declare", " ", "just", " ", "the", " ", "\"\<head\>\"", " ", "of", " ",
        "each", " ", "indexed", " ", "variable"}]}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", "b", ",", "s", ",", "p"}], "}"}], ",", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"initialize", " ", "values"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"a", "[", "0", "]"}], "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"b", "[", "0", "]"}], "=", 
      RowBox[{"1", "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"s", "[", "0", "]"}], "=", 
      RowBox[{"1", "/", "2"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"main", " ", "loop"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"a", "[", "k", "]"}], "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"a", "[", 
             RowBox[{"k", "-", "1"}], "]"}], "+", 
            RowBox[{"b", "[", 
             RowBox[{"k", "-", "1"}], "]"}]}], ")"}], "/", "2"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"b", "[", "k", "]"}], "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"a", "[", 
            RowBox[{"k", "-", "1"}], "]"}], "*", 
           RowBox[{"b", "[", 
            RowBox[{"k", "-", "1"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"s", "[", "k", "]"}], "=", 
         RowBox[{
          RowBox[{"s", "[", 
           RowBox[{"k", "-", "1"}], "]"}], "-", 
          RowBox[{
           RowBox[{"2", "^", "k"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"a", "[", "k", "]"}], "^", "2"}], "-", 
             RowBox[{
              RowBox[{"b", "[", "k", "]"}], "^", "2"}]}], ")"}]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"p", "[", "k", "]"}], "=", 
         RowBox[{"2", 
          RowBox[{
           RowBox[{
            RowBox[{"a", "[", "k", "]"}], "^", "2"}], "/", 
           RowBox[{"s", "[", "k", "]"}]}]}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "m"}], "}"}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"p", "[", "m", "]"}]}]}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"return", " ", "value"}], " ", "*)"}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.729987691441879*^9, 3.7299879314784636`*^9}, {
  3.729988074828987*^9, 3.72998807916083*^9}, {3.758961318437522*^9, 
  3.758961329926816*^9}, {3.8406332435117464`*^9, 3.840633251482625*^9}, {
  3.8414189429817657`*^9, 3.841418970473079*^9}, {3.9633247277765617`*^9, 
  3.963324749723873*^9}, {3.963324857770811*^9, 3.9633248907619095`*^9}},
 CellLabel->"In[37]:=",ExpressionUUID->"e342a519-870f-401a-95ad-92c39b73af75"],

Cell["\<\
Try out the module for a small parameter value, and note that it returns an \
exact expression.\
\>", "Text",
 CellChangeTimes->{{3.7299880826604643`*^9, 3.729988084928831*^9}, {
  3.8414189751767464`*^9, 3.84141897639521*^9}, {3.9633249025379734`*^9, 
  3.96332493866774*^9}},ExpressionUUID->"b208e26f-e8af-4e55-9aba-\
d9064277813d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"salaminBrent", "[", "1", "]"}]], "Input",
 CellChangeTimes->{{3.822688380994192*^9, 3.822688382474473*^9}, {
  3.8414189783757772`*^9, 3.8414189855683193`*^9}},
 CellLabel->"In[38]:=",ExpressionUUID->"2feb9b56-64d2-41c6-9603-ff93c4050fe3"],

Cell[BoxData[
 FractionBox[
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"1", "+", 
     FractionBox["1", 
      SqrtBox["2"]]}], ")"}], "2"], 
  RowBox[{"2", " ", 
   RowBox[{"(", 
    RowBox[{
     FractionBox["1", "2"], "-", 
     RowBox[{"2", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         FractionBox["1", 
          SqrtBox["2"]]}], "+", 
        RowBox[{
         FractionBox["1", "4"], " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", "+", 
            FractionBox["1", 
             SqrtBox["2"]]}], ")"}], "2"]}]}], ")"}]}]}], ")"}]}]]], "Output",
 CellChangeTimes->{
  3.8226883832559657`*^9, 3.8406272202844973`*^9, 3.840633259375989*^9, {
   3.8414189829803486`*^9, 3.8414189862780614`*^9}, 3.963324916023674*^9},
 CellLabel->"Out[38]=",ExpressionUUID->"6f6a59b4-46b4-5f4e-9034-f8c482eeb61f"]
}, Open  ]],

Cell["We can also convert the result to a decimal number.", "Text",
 CellChangeTimes->{{3.9633249216062527`*^9, 
  3.9633249541067867`*^9}},ExpressionUUID->"e957d618-3f35-c948-a19b-\
d66312715a15"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"N", "[", 
  RowBox[{
   RowBox[{"salaminBrent", "[", "1", "]"}], ",", "20"}], "]"}]], "Input",
 CellChangeTimes->{{3.8226883892706385`*^9, 3.822688389970224*^9}, {
  3.841418988659459*^9, 3.8414189940826426`*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"bc939bde-10a4-4f21-bccd-553c958b17d9"],

Cell[BoxData["3.18767264271210862720192997052536923267`20."], "Output",
 CellChangeTimes->{3.8226883905965505`*^9, 3.8406272222195206`*^9, 
  3.840633262625081*^9, 3.841418994301322*^9, 3.963324940667761*^9},
 CellLabel->"Out[39]=",ExpressionUUID->"3656a956-7766-3f4d-81ac-06f306c61e03"]
}, Open  ]],

Cell[TextData[{
 "We see that with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a62027b3-ab68-7242-9984-b84d2e62465c"],
 " we only get one correct digit of \[Pi] past the decimal point. Let\
\[CloseCurlyQuote]s run the algorithm again for each ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "05b682db-ff8a-4acb-ba29-2faa9717503d"],
 " up to 10 and print decimal versions of the approximations we compute"
}], "Text",
 CellChangeTimes->{{3.8414190071349106`*^9, 3.84141906634709*^9}, {
  3.9633249673729706`*^9, 
  3.96332499335001*^9}},ExpressionUUID->"3311205b-3c52-4e90-8219-\
c42fa1284724"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"piValues", "=", 
   RowBox[{"salaminBrent", "/@", 
    RowBox[{"Range", "[", "10", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"N", "[", 
  RowBox[{"piValues", ",", "60"}], "]"}]}], "Input",
 CellChangeTimes->{{3.840627266408063*^9, 3.840627313110297*^9}, 
   3.8406333091664977`*^9, {3.840633351273885*^9, 3.840633375827084*^9}, {
   3.841419068275115*^9, 3.8414190943233995`*^9}, {3.963324984173397*^9, 
   3.9633249968260937`*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"9ac6a322-7bba-4b66-bd04-5913510a3b20"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "3.1876726427121086272019299705253692326510535718593692264876339862751228325\
2806`60.", ",", 
   "3.141680293297653293918070424560009382795719438815402832644189463195663001\
01005`60.", ",", 
   "3.141592653895446496002914758818043486108879237261311589651101357684653079\
50313`60.", ",", 
   "3.141592653589793238466360602706631321757702411342429356486846015238410948\
60698`60.", ",", 
   "3.141592653589793238462643383279502884197169949164726605834696125948748006\
09534`60.", ",", 
